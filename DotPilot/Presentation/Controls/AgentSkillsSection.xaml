<UserControl x:Class="DotPilot.Presentation.Controls.AgentSkillsSection"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             FontFamily="{StaticResource AppBodyFontFamily}">
  <Border Style="{StaticResource SectionCardStyle}"
          AutomationProperties.AutomationId="AgentSkillsSection">
    <StackPanel Spacing="12">
      <Grid ColumnSpacing="12">
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="Auto" />
          <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>
        <Border Width="26"
                Height="26"
                CornerRadius="8"
                Background="{StaticResource AppPrimaryTextBrush}">
          <TextBlock HorizontalAlignment="Center"
                     VerticalAlignment="Center"
                     FontFamily="{StaticResource AppAccentFontFamily}"
                     FontSize="11.5"
                     FontWeight="Bold"
                     Foreground="{StaticResource AppAccentBrush}"
                     Text="3" />
        </Border>
        <TextBlock Grid.Column="1"
                   VerticalAlignment="Center"
                   FontSize="14"
                   FontWeight="SemiBold"
                   Text="Skills" />
      </Grid>

      <ItemsControl AutomationProperties.AutomationId="SkillsList"
                    ItemsSource="{Binding Skills}">
        <ItemsControl.ItemTemplate>
          <DataTemplate>
            <StackPanel Spacing="0">
              <Grid Margin="0,0,0,12"
                    ColumnSpacing="12">
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="Auto" />
                  <ColumnDefinition Width="*" />
                  <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <Border Width="36"
                        Height="36"
                        CornerRadius="10"
                        Background="{StaticResource AppSoftSurfaceBrush}"
                        VerticalAlignment="Center">
                  <TextBlock HorizontalAlignment="Center"
                             VerticalAlignment="Center"
                             FontSize="14"
                             Text="{Binding IconGlyph}" />
                </Border>
                <StackPanel Grid.Column="1"
                            VerticalAlignment="Center"
                            Spacing="2">
                  <TextBlock FontSize="13"
                             FontWeight="SemiBold"
                             Text="{Binding Name}" />
                  <TextBlock FontSize="11.5"
                             Foreground="{StaticResource AppMutedTextBrush}"
                             Text="{Binding Description}"
                             TextWrapping="Wrap" />
                </StackPanel>
                <ToggleSwitch Grid.Column="2"
                              HorizontalAlignment="Right"
                              IsOn="{Binding IsEnabled, Mode=OneWay}"
                              OnContent=""
                              OffContent=""
                              VerticalAlignment="Center" />
              </Grid>
              <Rectangle Style="{StaticResource SectionDividerStyle}" />
            </StackPanel>
          </DataTemplate>
        </ItemsControl.ItemTemplate>
      </ItemsControl>
    </StackPanel>
  </Border>
</UserControl>
