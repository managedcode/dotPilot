<UserControl x:Class="DotPilot.Presentation.Controls.AgentSkillsSection"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:presentation="using:DotPilot.Presentation"
             FontFamily="{StaticResource AppBodyFontFamily}">
  <Border Style="{StaticResource BuilderSectionStyle}"
          AutomationProperties.AutomationId="AgentSkillsSection">
    <StackPanel Spacing="18">
      <StackPanel Spacing="6">
        <TextBlock FontSize="18"
                   FontWeight="SemiBold"
                   Text="Tools and skills" />
        <TextBlock FontSize="12"
                   Foreground="{StaticResource AppMutedTextBrush}"
                   Text="Keep the runtime scope explicit: enable the tools the agent can use and the skills it should lean on."
                   TextWrapping="WrapWholeWords" />
      </StackPanel>

      <StackPanel Spacing="10">
        <TextBlock FontSize="12"
                   FontWeight="Medium"
                   Foreground="{StaticResource AppSecondaryTextBrush}"
                   Text="Tools" />
        <ItemsControl AutomationProperties.AutomationId="AgentToolsList"
                      ItemsSource="{Binding Tools}">
          <ItemsControl.ItemTemplate>
            <DataTemplate x:DataType="presentation:SelectionOption">
              <Border Style="{StaticResource BuilderSummaryCardStyle}"
                      Margin="0,0,0,10">
                <Grid ColumnSpacing="12">
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                  </Grid.ColumnDefinitions>
                  <StackPanel Spacing="4">
                    <TextBlock FontSize="13"
                               FontWeight="SemiBold"
                               Text="{x:Bind Label}" />
                    <TextBlock FontSize="11.5"
                               Foreground="{StaticResource AppMutedTextBrush}"
                               Text="{x:Bind Description}"
                               TextWrapping="WrapWholeWords" />
                  </StackPanel>

                  <ToggleSwitch Grid.Column="1"
                                HorizontalAlignment="Right"
                                OffContent=""
                                OnContent=""
                                VerticalAlignment="Top"
                                IsOn="{x:Bind IsEnabled, Mode=TwoWay}" />
                </Grid>
              </Border>
            </DataTemplate>
          </ItemsControl.ItemTemplate>
        </ItemsControl>
      </StackPanel>

      <StackPanel Spacing="10">
        <TextBlock FontSize="12"
                   FontWeight="Medium"
                   Foreground="{StaticResource AppSecondaryTextBrush}"
                   Text="Skills" />
        <ItemsControl AutomationProperties.AutomationId="AgentSkillList"
                      ItemsSource="{Binding Skills}">
          <ItemsControl.ItemTemplate>
            <DataTemplate x:DataType="presentation:SelectionOption">
              <Border Style="{StaticResource BuilderSummaryCardStyle}"
                      Margin="0,0,0,10">
                <Grid ColumnSpacing="12">
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                  </Grid.ColumnDefinitions>
                  <StackPanel Spacing="4">
                    <TextBlock FontSize="13"
                               FontWeight="SemiBold"
                               Text="{x:Bind Label}" />
                    <TextBlock FontSize="11.5"
                               Foreground="{StaticResource AppMutedTextBrush}"
                               Text="{x:Bind Description}"
                               TextWrapping="WrapWholeWords" />
                  </StackPanel>

                  <ToggleSwitch Grid.Column="1"
                                HorizontalAlignment="Right"
                                OffContent=""
                                OnContent=""
                                VerticalAlignment="Top"
                                IsOn="{x:Bind IsEnabled, Mode=TwoWay}" />
                </Grid>
              </Border>
            </DataTemplate>
          </ItemsControl.ItemTemplate>
        </ItemsControl>
      </StackPanel>
    </StackPanel>
  </Border>
</UserControl>
