<UserControl x:Class="DotPilot.Presentation.Controls.AgentSkillsSection"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:presentation="using:DotPilot.Presentation"
             FontFamily="{StaticResource AppBodyFontFamily}">
  <Border Style="{StaticResource BuilderSectionStyle}"
          AutomationProperties.AutomationId="AgentSkillsSection">
    <StackPanel Spacing="18">
      <StackPanel Spacing="6">
        <TextBlock FontSize="18"
                   FontWeight="SemiBold"
                   Text="Capabilities" />
        <TextBlock FontSize="12.5"
                   Foreground="{StaticResource AppMutedTextBrush}"
                   Text="Choose what this agent is allowed to handle inside each local workflow session."
                   TextWrapping="WrapWholeWords" />
      </StackPanel>

      <ItemsControl AutomationProperties.AutomationId="SkillsList"
                    ItemsSource="{Binding Capabilities}">
        <ItemsControl.ItemTemplate>
          <DataTemplate x:DataType="presentation:CapabilityOption">
            <Border Style="{StaticResource BuilderSummaryCardStyle}"
                    Margin="0,0,0,12">
              <Grid ColumnSpacing="12">
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="Auto" />
                  <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <CheckBox VerticalAlignment="Top"
                          IsChecked="{x:Bind IsEnabled, Mode=TwoWay}" />
                <StackPanel Grid.Column="1"
                            Spacing="4">
                  <TextBlock FontSize="13"
                             FontWeight="SemiBold"
                             Text="{x:Bind Name}" />
                  <TextBlock FontSize="11.5"
                             Foreground="{StaticResource AppMutedTextBrush}"
                             Text="{x:Bind Description}"
                             TextWrapping="WrapWholeWords" />
                </StackPanel>
              </Grid>
            </Border>
          </DataTemplate>
        </ItemsControl.ItemTemplate>
      </ItemsControl>
    </StackPanel>
  </Border>
</UserControl>
