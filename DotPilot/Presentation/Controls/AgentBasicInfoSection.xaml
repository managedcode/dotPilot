<UserControl x:Class="DotPilot.Presentation.Controls.AgentBasicInfoSection"
             x:Name="Root"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             FontFamily="{StaticResource AppBodyFontFamily}">
  <Border Style="{StaticResource SectionCardStyle}"
          AutomationProperties.AutomationId="AgentBasicInfoSection">
    <StackPanel Spacing="16">
      <Grid ColumnSpacing="12">
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="Auto" />
          <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>
        <Border Width="26"
                Height="26"
                CornerRadius="8"
                Background="{StaticResource AppPrimaryTextBrush}">
          <TextBlock HorizontalAlignment="Center"
                     VerticalAlignment="Center"
                     FontFamily="{StaticResource AppAccentFontFamily}"
                     FontSize="11.5"
                     FontWeight="Bold"
                     Foreground="{StaticResource AppAccentBrush}"
                     Text="1" />
        </Border>
        <TextBlock Grid.Column="1"
                   VerticalAlignment="Center"
                   FontSize="14"
                   FontWeight="SemiBold"
                   Text="Basic Information" />
      </Grid>

      <Grid ColumnSpacing="12">
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="7*" MinWidth="240" />
          <ColumnDefinition Width="5*" MinWidth="260" />
        </Grid.ColumnDefinitions>

        <StackPanel Spacing="6">
          <TextBlock FontSize="12"
                     FontWeight="Medium"
                     Foreground="{StaticResource AppSecondaryTextBrush}"
                     Text="Agent Name" />
          <Border Style="{StaticResource InputSurfaceStyle}"
                  MinWidth="240">
            <TextBox Background="Transparent"
                     BorderThickness="0"
                     FontSize="12"
                     PlaceholderText="e.g. Research Assistant"
                     TextAlignment="Left" />
          </Border>
        </StackPanel>

        <StackPanel x:Name="AgentTypePanel"
                    Grid.Column="1"
                    Spacing="8">
          <TextBlock FontSize="12"
                     FontWeight="Medium"
                     Foreground="{StaticResource AppSecondaryTextBrush}"
                     Text="Agent Type" />
          <ScrollViewer HorizontalScrollBarVisibility="Auto"
                        HorizontalScrollMode="Enabled"
                        VerticalScrollBarVisibility="Disabled"
                        VerticalScrollMode="Disabled">
            <ItemsControl ItemsSource="{Binding AgentTypes}">
              <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                  <StackPanel Orientation="Horizontal"
                              Spacing="6" />
                </ItemsPanelTemplate>
              </ItemsControl.ItemsPanel>
              <ItemsControl.ItemTemplate>
                <DataTemplate>
                  <Border Style="{StaticResource SearchSurfaceStyle}"
                          Margin="0,0,6,0"
                          Padding="14,8">
                    <StackPanel Orientation="Horizontal"
                                Spacing="8">
                      <Border Width="18"
                              Height="18"
                              Background="{StaticResource AppAccentBrush}"
                              CornerRadius="9"
                              Visibility="{Binding IsSelected}">
                        <TextBlock HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   FontFamily="{StaticResource AppAccentFontFamily}"
                                   FontSize="10"
                                   Foreground="{StaticResource AppPrimaryTextBrush}"
                                   Text="✓" />
                      </Border>
                      <TextBlock FontSize="12"
                                 FontWeight="Medium"
                                 Foreground="{StaticResource AppPrimaryTextBrush}"
                                 Text="{Binding Label}" />
                    </StackPanel>
                  </Border>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>
          </ScrollViewer>
        </StackPanel>
      </Grid>

      <StackPanel Spacing="6">
        <TextBlock FontSize="12"
                   FontWeight="Medium"
                   Foreground="{StaticResource AppSecondaryTextBrush}"
                   Text="Description" />
        <Border Style="{StaticResource LargeInputSurfaceStyle}">
          <TextBox AcceptsReturn="True"
                   Background="Transparent"
                   BorderThickness="0"
                   FontSize="12"
                   MinHeight="76"
                   PlaceholderText="Describe what this agent does and its primary role..."
                   TextWrapping="Wrap" />
        </Border>
      </StackPanel>

      <StackPanel Spacing="6">
        <TextBlock FontSize="12"
                   FontWeight="Medium"
                   Foreground="{StaticResource AppSecondaryTextBrush}"
                   Text="Avatar" />
        <ScrollViewer HorizontalScrollBarVisibility="Auto"
                      HorizontalScrollMode="Enabled"
                      VerticalScrollBarVisibility="Disabled"
                      VerticalScrollMode="Disabled">
          <ItemsControl ItemsSource="{Binding AvatarOptions}">
            <ItemsControl.ItemsPanel>
              <ItemsPanelTemplate>
                <StackPanel Orientation="Horizontal"
                            Spacing="8" />
              </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
            <ItemsControl.ItemTemplate>
              <DataTemplate>
                <Border Width="44"
                        Height="44"
                        CornerRadius="22"
                        Background="{Binding AvatarBrush}"
                        Margin="0,0,8,0">
                  <TextBlock HorizontalAlignment="Center"
                             VerticalAlignment="Center"
                             FontSize="16"
                             FontWeight="Bold"
                             Foreground="{StaticResource AppInputSurfaceBrush}"
                             Text="{Binding Initial}" />
                </Border>
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>
        </ScrollViewer>
      </StackPanel>
    </StackPanel>
  </Border>
</UserControl>
