<UserControl x:Class="DotPilot.Presentation.Controls.AgentBasicInfoSection"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:presentation="using:DotPilot.Presentation"
             FontFamily="{StaticResource AppBodyFontFamily}">
  <Border Style="{StaticResource BuilderSectionStyle}"
          AutomationProperties.AutomationId="AgentBasicInfoSection">
    <StackPanel Spacing="18">
      <StackPanel Spacing="6">
        <TextBlock FontSize="18"
                   FontWeight="SemiBold"
                   Text="Profile" />
        <TextBlock FontSize="12.5"
                   Foreground="{StaticResource AppMutedTextBrush}"
                   Text="Pick the provider, role, and model behavior for a reusable local agent profile."
                   TextWrapping="WrapWholeWords" />
      </StackPanel>

      <Grid ColumnSpacing="16"
            RowSpacing="16">
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="1.35*" MinWidth="260" />
          <ColumnDefinition Width="*" MinWidth="220" />
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
          <RowDefinition Height="Auto" />
          <RowDefinition Height="Auto" />
          <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Spacing="8">
          <TextBlock FontSize="12"
                     FontWeight="Medium"
                     Foreground="{StaticResource AppSecondaryTextBrush}"
                     Text="Agent name" />
          <Border Style="{StaticResource BuilderInputSurfaceStyle}">
            <TextBox AutomationProperties.AutomationId="AgentNameInput"
                     Style="{StaticResource BuilderTextBoxStyle}"
                     PlaceholderText="e.g. Repository reviewer"
                     Text="{Binding AgentName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
          </Border>
        </StackPanel>

        <StackPanel Grid.Column="1"
                    Spacing="8">
          <TextBlock FontSize="12"
                     FontWeight="Medium"
                     Foreground="{StaticResource AppSecondaryTextBrush}"
                     Text="Role" />
          <Border Style="{StaticResource BuilderInputSurfaceStyle}">
            <ComboBox AutomationProperties.AutomationId="AgentRoleCombo"
                      Style="{StaticResource BuilderComboBoxStyle}"
                      DisplayMemberPath="Label"
                      ItemsSource="{Binding Roles}"
                      SelectedItem="{Binding SelectedRole, Mode=TwoWay}" />
          </Border>
        </StackPanel>

        <StackPanel Grid.Row="1"
                    Grid.ColumnSpan="2"
                    Spacing="8">
          <TextBlock FontSize="12"
                     FontWeight="Medium"
                     Foreground="{StaticResource AppSecondaryTextBrush}"
                     Text="Provider" />
          <Border Style="{StaticResource BuilderInputSurfaceStyle}">
            <ComboBox AutomationProperties.AutomationId="AgentProviderCombo"
                      Style="{StaticResource BuilderComboBoxStyle}"
                      DisplayMemberPath="DisplayName"
                      ItemsSource="{Binding Providers}"
                      SelectedItem="{Binding SelectedProvider, Mode=TwoWay}" />
          </Border>
        </StackPanel>

        <StackPanel Grid.Row="2"
                    Spacing="8">
          <TextBlock FontSize="12"
                     FontWeight="Medium"
                     Foreground="{StaticResource AppSecondaryTextBrush}"
                     Text="Model override" />
          <Border Style="{StaticResource BuilderInputSurfaceStyle}">
            <TextBox AutomationProperties.AutomationId="AgentModelInput"
                     Style="{StaticResource BuilderTextBoxStyle}"
                     PlaceholderText="{Binding Builder.SuggestedModelName}"
                     Text="{Binding ModelName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
          </Border>
          <TextBlock AutomationProperties.AutomationId="AgentSuggestedModelText"
                     FontSize="11.5"
                     Foreground="{StaticResource AppMutedTextBrush}"
                     TextWrapping="WrapWholeWords">
            <Run Text="Leave blank to use " />
            <Run Text="{Binding Builder.SuggestedModelName}" />
            <Run Text="." />
          </TextBlock>
        </StackPanel>

        <Border Grid.Row="2"
                Grid.Column="1"
                Style="{StaticResource BuilderSummaryCardStyle}"
                AutomationProperties.AutomationId="AgentProviderSummaryCard">
          <StackPanel Spacing="6">
            <TextBlock FontSize="13"
                       FontWeight="SemiBold"
                       Text="{Binding Builder.ProviderDisplayName}" />
            <TextBlock FontSize="12"
                       Foreground="{StaticResource AppMutedTextBrush}"
                       Text="{Binding Builder.ProviderStatusSummary}"
                       TextWrapping="WrapWholeWords" />
            <TextBlock FontSize="11.5"
                       Foreground="{StaticResource AppSecondaryTextBrush}"
                       Text="{Binding Builder.ProviderCommandName}" />
            <TextBlock FontSize="11.5"
                       Foreground="{StaticResource AppSecondaryTextBrush}"
                       Text="{Binding Builder.ProviderVersionLabel}"
                       Visibility="{Binding Builder.HasProviderVersion}" />
          </StackPanel>
        </Border>
      </Grid>
    </StackPanel>
  </Border>
</UserControl>
