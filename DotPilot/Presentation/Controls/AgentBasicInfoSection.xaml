<UserControl x:Class="DotPilot.Presentation.Controls.AgentBasicInfoSection"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:presentation="using:DotPilot.Presentation"
             FontFamily="{StaticResource AppBodyFontFamily}">
  <Border Style="{StaticResource SectionCardStyle}"
          AutomationProperties.AutomationId="AgentBasicInfoSection">
    <StackPanel Spacing="16">
      <Grid ColumnSpacing="12">
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="Auto" />
          <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>
        <Border Width="26"
                Height="26"
                CornerRadius="8"
                Background="{StaticResource AppPrimaryTextBrush}">
          <TextBlock HorizontalAlignment="Center"
                     VerticalAlignment="Center"
                     FontFamily="{StaticResource AppAccentFontFamily}"
                     FontSize="11.5"
                     FontWeight="Bold"
                     Foreground="{StaticResource AppAccentBrush}"
                     Text="1" />
        </Border>
        <TextBlock Grid.Column="1"
                   VerticalAlignment="Center"
                   FontSize="14"
                   FontWeight="SemiBold"
                   Text="Basic information" />
      </Grid>

      <Grid ColumnSpacing="12">
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="*" MinWidth="220" />
          <ColumnDefinition Width="*" MinWidth="220" />
        </Grid.ColumnDefinitions>

        <StackPanel Spacing="6">
          <TextBlock FontSize="12"
                     FontWeight="Medium"
                     Foreground="{StaticResource AppSecondaryTextBrush}"
                     Text="Agent name" />
          <Border Style="{StaticResource InputSurfaceStyle}">
            <TextBox AutomationProperties.AutomationId="AgentNameInput"
                     Background="Transparent"
                     BorderThickness="0"
                     FontSize="12"
                     PlaceholderText="e.g. Code Reviewer"
                     Text="{Binding AgentName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
          </Border>
        </StackPanel>

        <StackPanel Grid.Column="1"
                    Spacing="6">
          <TextBlock FontSize="12"
                     FontWeight="Medium"
                     Foreground="{StaticResource AppSecondaryTextBrush}"
                     Text="Provider" />
          <Border Style="{StaticResource InputSurfaceStyle}">
            <ComboBox AutomationProperties.AutomationId="AgentProviderCombo"
                      Background="Transparent"
                      BorderThickness="0"
                      DisplayMemberPath="DisplayName"
                      ItemsSource="{Binding Providers}"
                      SelectedItem="{Binding SelectedProvider, Mode=TwoWay}" />
          </Border>
        </StackPanel>
      </Grid>

      <Grid ColumnSpacing="12">
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="*" />
          <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <StackPanel Spacing="6">
          <TextBlock FontSize="12"
                     FontWeight="Medium"
                     Foreground="{StaticResource AppSecondaryTextBrush}"
                     Text="Model" />
          <Border Style="{StaticResource InputSurfaceStyle}">
            <TextBox AutomationProperties.AutomationId="AgentModelInput"
                     Background="Transparent"
                     BorderThickness="0"
                     FontSize="12"
                     PlaceholderText="gpt-5 / claude-sonnet-4-5 / debug-echo"
                     Text="{Binding ModelName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
          </Border>
        </StackPanel>

        <StackPanel Grid.Column="1"
                    Spacing="8">
          <TextBlock FontSize="12"
                     FontWeight="Medium"
                     Foreground="{StaticResource AppSecondaryTextBrush}"
                     Text="Role" />
          <ItemsControl ItemsSource="{Binding Roles}">
            <ItemsControl.ItemsPanel>
              <ItemsPanelTemplate>
                <StackPanel Orientation="Horizontal"
                            Spacing="10" />
              </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
            <ItemsControl.ItemTemplate>
              <DataTemplate x:DataType="presentation:RoleOption">
                <RadioButton Content="{x:Bind Label}"
                             GroupName="AgentRoleOptions"
                             IsChecked="{x:Bind IsSelected, Mode=TwoWay}" />
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>
        </StackPanel>
      </Grid>

      <Border Background="{StaticResource AppSoftSurfaceBrush}"
              BorderBrush="{StaticResource AppOutlineBrush}"
              BorderThickness="1"
              CornerRadius="16"
              AutomationProperties.AutomationId="AgentProviderSummaryCard"
              Padding="12,10">
        <StackPanel Spacing="4">
          <TextBlock FontSize="12"
                     FontWeight="SemiBold"
                     Text="{Binding SelectedProvider.DisplayName}" />
          <TextBlock FontSize="12"
                     Foreground="{StaticResource AppMutedTextBrush}"
                     Text="{Binding SelectedProvider.StatusSummary}"
                     TextWrapping="WrapWholeWords" />
          <TextBlock FontSize="11"
                     Foreground="{StaticResource AppMutedTextBrush}"
                     Text="{Binding SelectedProvider.CommandName}" />
        </StackPanel>
      </Border>
    </StackPanel>
  </Border>
</UserControl>
