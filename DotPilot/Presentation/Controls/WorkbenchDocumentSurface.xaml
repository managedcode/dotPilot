<UserControl x:Class="DotPilot.Presentation.Controls.WorkbenchDocumentSurface"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:workbench="using:DotPilot.Core.Features.Workbench"
             AutomationProperties.AutomationId="WorkbenchDocumentSurface">
  <Border Style="{StaticResource GlassPanelStyle}">
    <Grid RowSpacing="16">
      <Grid.RowDefinitions>
        <RowDefinition Height="Auto" />
        <RowDefinition Height="Auto" />
        <RowDefinition Height="*" />
      </Grid.RowDefinitions>

      <Grid ColumnSpacing="12">
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="*" />
          <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>
        <StackPanel Spacing="4">
          <TextBlock CharacterSpacing="80"
                     FontSize="11"
                     FontWeight="Medium"
                     Foreground="{StaticResource AppMutedTextBrush}"
                     Text="FILE SURFACE" />
          <TextBlock AutomationProperties.AutomationId="SelectedDocumentTitle"
                     FontSize="20"
                     FontWeight="SemiBold"
                     Text="{Binding SelectedDocumentTitle}" />
          <TextBlock AutomationProperties.AutomationId="SelectedDocumentPath"
                     FontSize="12"
                     Foreground="{StaticResource AppMutedTextBrush}"
                     Text="{Binding SelectedDocumentPath}"
                     TextWrapping="WrapWholeWords" />
        </StackPanel>
        <ToggleSwitch Grid.Column="1"
                      AutomationProperties.AutomationId="DocumentViewModeToggle"
                      Header="Diff review"
                      IsOn="{Binding IsDiffReviewMode, Mode=TwoWay}"
                      OffContent="Preview"
                      OnContent="Diff" />
      </Grid>

      <Grid Grid.Row="1"
            ColumnSpacing="12">
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="Auto" />
          <ColumnDefinition Width="Auto" />
          <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Border Background="{StaticResource AppSoftSurfaceBrush}"
                CornerRadius="100"
                Padding="12,6">
          <TextBlock FontSize="11"
                     Foreground="{StaticResource AppPrimaryTextBrush}"
                     Text="{Binding SelectedDocumentLanguage}" />
        </Border>

        <Border Grid.Column="1"
                Background="{StaticResource AppSoftSurfaceBrush}"
                CornerRadius="100"
                Padding="12,6">
          <TextBlock FontSize="11"
                     Foreground="{StaticResource AppPrimaryTextBrush}"
                     Text="{Binding SelectedDocumentRenderer}" />
        </Border>

        <Border Grid.Column="2"
                Background="{StaticResource AppBadgeSurfaceBrush}"
                CornerRadius="100"
                HorizontalAlignment="Left"
                Padding="12,6">
          <TextBlock AutomationProperties.AutomationId="SelectedDocumentStatus"
                     FontSize="11"
                     Foreground="{StaticResource AppPrimaryTextBrush}"
                     Text="{Binding SelectedDocumentStatus}" />
        </Border>
      </Grid>

      <Grid Grid.Row="2">
        <Border Style="{StaticResource LargeInputSurfaceStyle}"
                Visibility="{Binding IsPreviewMode}">
          <ScrollViewer AutomationProperties.AutomationId="WorkbenchPreviewEditor"
                        HorizontalScrollBarVisibility="Auto"
                        VerticalScrollBarVisibility="Auto">
            <TextBlock Margin="4"
                       MinHeight="420"
                       Foreground="{StaticResource AppPrimaryTextBrush}"
                       Text="{Binding EditablePreviewContent}"
                       TextWrapping="NoWrap" />
          </ScrollViewer>
        </Border>

        <ScrollViewer Visibility="{Binding IsDiffReviewMode}"
                      VerticalScrollBarVisibility="Auto">
          <StackPanel AutomationProperties.AutomationId="WorkbenchDiffLinesList"
                      Spacing="10">
            <ItemsControl ItemsSource="{Binding SelectedDocumentDiffLines}">
              <ItemsControl.ItemTemplate>
                <DataTemplate x:DataType="workbench:WorkbenchDiffLine">
                  <Border Background="{StaticResource AppSoftSurfaceBrush}"
                          BorderBrush="{StaticResource AppOutlineBrush}"
                          BorderThickness="1"
                          CornerRadius="14"
                          Padding="12,10">
                    <Grid AutomationProperties.AutomationId="WorkbenchDiffLineItem"
                          ColumnSpacing="10">
                      <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                      </Grid.ColumnDefinitions>
                      <TextBlock FontSize="11"
                                 Foreground="{StaticResource AppMutedTextBrush}"
                                 Text="{x:Bind Kind}" />
                      <TextBlock Grid.Column="1"
                                 FontSize="12"
                                 Text="{x:Bind Content}"
                                 TextWrapping="WrapWholeWords" />
                    </Grid>
                  </Border>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>
          </StackPanel>
        </ScrollViewer>
      </Grid>
    </Grid>
  </Border>
</UserControl>
