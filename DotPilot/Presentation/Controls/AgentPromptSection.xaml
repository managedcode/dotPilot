<UserControl x:Class="DotPilot.Presentation.Controls.AgentPromptSection"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             FontFamily="{StaticResource AppBodyFontFamily}">
  <Border Style="{StaticResource SectionCardStyle}"
          AutomationProperties.AutomationId="AgentPromptSection">
    <StackPanel Spacing="15">
      <Grid ColumnSpacing="12">
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="Auto" />
          <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>
        <Border Width="26"
                Height="26"
                CornerRadius="8"
                Background="{StaticResource AppPrimaryTextBrush}">
          <TextBlock HorizontalAlignment="Center"
                     VerticalAlignment="Center"
                     FontFamily="{StaticResource AppAccentFontFamily}"
                     FontSize="11.5"
                     FontWeight="Bold"
                     Foreground="{StaticResource AppAccentBrush}"
                     Text="2" />
        </Border>
        <TextBlock Grid.Column="1"
                   VerticalAlignment="Center"
                   FontSize="14"
                   FontWeight="SemiBold"
                   Text="System prompt" />
      </Grid>

      <Grid ColumnSpacing="12">
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="Auto" />
          <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>
        <Button
                AutomationProperties.AutomationId="CreateAgentButton"
                Background="{StaticResource AppAccentBrush}"
                BorderBrush="Transparent"
                BorderThickness="0"
                Command="{Binding CreateAgentCommand}"
                CornerRadius="18"
                Padding="16,10">
          <TextBlock FontSize="12"
                     FontWeight="SemiBold"
                     Foreground="{StaticResource AppPrimaryTextBrush}"
                     Text="Create agent" />
        </Button>
        <TextBlock Grid.Column="1"
                   Margin="12,0,0,0"
                   VerticalAlignment="Center"
                   AutomationProperties.AutomationId="AgentCreateStatusMessage"
                   FontSize="12"
                   Foreground="{StaticResource AppMutedTextBrush}"
                   Text="{Binding StatusMessage}"
                   TextWrapping="WrapWholeWords" />
      </Grid>

      <Border Style="{StaticResource LargeInputSurfaceStyle}"
              MinHeight="176">
        <TextBox AutomationProperties.AutomationId="AgentSystemPromptInput"
                 AcceptsReturn="True"
                 Background="Transparent"
                 BorderThickness="0"
                 FontSize="12"
                 Foreground="{StaticResource AppPrimaryTextBrush}"
                 Text="{Binding SystemPrompt, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                 TextWrapping="Wrap" />
      </Border>
    </StackPanel>
  </Border>
</UserControl>
