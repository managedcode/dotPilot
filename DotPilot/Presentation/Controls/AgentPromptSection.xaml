<UserControl x:Class="DotPilot.Presentation.Controls.AgentPromptSection"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             FontFamily="{StaticResource AppBodyFontFamily}">
  <Border Style="{StaticResource BuilderSectionStyle}"
          AutomationProperties.AutomationId="AgentPromptSection">
    <StackPanel Spacing="18">
      <StackPanel Spacing="6">
        <TextBlock FontSize="18"
                   FontWeight="SemiBold"
                   Text="Behavior" />
        <TextBlock FontSize="12.5"
                   Foreground="{StaticResource AppMutedTextBrush}"
                   Text="Write the baseline prompt this local agent should carry into each session."
                   TextWrapping="WrapWholeWords" />
      </StackPanel>

      <Border Style="{StaticResource BuilderSummaryCardStyle}"
              MinHeight="224">
        <TextBox AutomationProperties.AutomationId="AgentSystemPromptInput"
                 AcceptsReturn="True"
                 Style="{StaticResource BuilderTextBoxStyle}"
                 Foreground="{StaticResource AppPrimaryTextBrush}"
                 Text="{Binding SystemPrompt, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                 TextWrapping="Wrap" />
      </Border>

      <Grid ColumnSpacing="16">
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="*" />
          <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>
        <StackPanel Grid.Column="0"
                    VerticalAlignment="Center"
                    Spacing="4">
          <TextBlock AutomationProperties.AutomationId="AgentCreateHelperMessage"
                     FontSize="12"
                     Foreground="{StaticResource AppMutedTextBrush}"
                     Text="{Binding Builder.StatusMessage}"
                     TextWrapping="WrapWholeWords" />
          <TextBlock AutomationProperties.AutomationId="AgentCreateStatusMessage"
                     FontSize="12"
                     Foreground="{StaticResource AppPrimaryTextBrush}"
                     Text="{Binding OperationMessage}"
                     TextWrapping="WrapWholeWords" />
        </StackPanel>
        <Button Grid.Column="1"
                AutomationProperties.AutomationId="CreateAgentButton"
                Background="{StaticResource AppAccentBrush}"
                BorderBrush="Transparent"
                BorderThickness="0"
                Command="{Binding CreateAgent}"
                CornerRadius="16"
                IsEnabled="{Binding Builder.CanCreateAgent}"
                Padding="18,12">
          <TextBlock FontSize="12.5"
                     FontWeight="SemiBold"
                     Foreground="{StaticResource AppPrimaryTextBrush}"
                     Text="Create agent" />
        </Button>
      </Grid>
    </StackPanel>
  </Border>
</UserControl>
