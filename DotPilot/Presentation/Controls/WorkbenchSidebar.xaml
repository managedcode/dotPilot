<UserControl x:Class="DotPilot.Presentation.Controls.WorkbenchSidebar"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:muxc="using:Microsoft.UI.Xaml.Controls"
             xmlns:presentation="using:DotPilot.Presentation"
             xmlns:uen="using:Uno.Extensions.Navigation.UI"
             AutomationProperties.AutomationId="WorkbenchSidebar"
             FontFamily="{StaticResource AppBodyFontFamily}">
  <Border Style="{StaticResource GlassPanelStyle}"
          Padding="0">
    <Grid>
      <Grid.RowDefinitions>
        <RowDefinition Height="Auto" />
        <RowDefinition Height="Auto" />
        <RowDefinition Height="Auto" />
        <RowDefinition Height="*" />
        <RowDefinition Height="Auto" />
      </Grid.RowDefinitions>

      <StackPanel Margin="16,18,16,0"
                  Orientation="Horizontal"
                  Spacing="10">
        <Border Width="36"
                Height="36"
                Background="{StaticResource AppPrimaryTextBrush}"
                CornerRadius="11">
          <TextBlock HorizontalAlignment="Center"
                     VerticalAlignment="Center"
                     FontFamily="{StaticResource AppAccentFontFamily}"
                     FontSize="11"
                     Foreground="{StaticResource AppAccentBrush}"
                     Text="dp" />
        </Border>
        <TextBlock VerticalAlignment="Center"
                   FontSize="18"
                   FontWeight="SemiBold"
                   Foreground="{StaticResource AppPrimaryTextBrush}">
          <Run Text="dot" />
          <Run FontWeight="Normal"
               Foreground="{StaticResource AppMutedTextBrush}"
               Text="Pilot" />
        </TextBlock>
      </StackPanel>

      <StackPanel Grid.Row="1"
                  Margin="12,20,12,0"
                  Spacing="4">
        <Button x:Name="WorkbenchNavButton"
                AutomationProperties.AutomationId="WorkbenchNavButton"
                Style="{StaticResource SidebarButtonSelectedStyle}">
          <StackPanel Orientation="Horizontal"
                      Spacing="8">
            <TextBlock VerticalAlignment="Center"
                       FontSize="13"
                       Text="◌" />
            <TextBlock VerticalAlignment="Center"
                       Text="Workbench" />
          </StackPanel>
        </Button>
        <Button AutomationProperties.AutomationId="SidebarAgentsButton"
                Style="{StaticResource SidebarButtonStyle}"
                uen:Navigation.Request="Second">
          <StackPanel Orientation="Horizontal"
                      Spacing="8">
            <TextBlock VerticalAlignment="Center"
                       FontSize="13"
                       Text="✦" />
            <TextBlock VerticalAlignment="Center"
                       Text="Agents" />
          </StackPanel>
        </Button>
        <Button AutomationProperties.AutomationId="SidebarSettingsButton"
                Style="{StaticResource SidebarButtonStyle}"
                uen:Navigation.Request="Settings">
          <StackPanel Orientation="Horizontal"
                      Spacing="8">
            <TextBlock VerticalAlignment="Center"
                       FontSize="13"
                       Text="⌘" />
            <TextBlock VerticalAlignment="Center"
                       Text="Settings" />
          </StackPanel>
        </Button>
      </StackPanel>

      <Rectangle Grid.Row="2"
                 Margin="12,18,12,0"
                 Style="{StaticResource SectionDividerStyle}" />

      <StackPanel Grid.Row="3"
                  Margin="12,20,12,16"
                  Spacing="16">
        <StackPanel Spacing="4">
          <TextBlock CharacterSpacing="80"
                     FontSize="11"
                     FontWeight="Medium"
                     Foreground="{StaticResource AppMutedTextBrush}"
                     Text="{Binding EpicLabel}" />
          <TextBlock FontSize="18"
                     FontWeight="SemiBold"
                     Text="{Binding WorkspaceName}" />
          <TextBlock FontSize="12"
                     Foreground="{StaticResource AppMutedTextBrush}"
                     Text="{Binding WorkspaceRoot}"
                     TextWrapping="WrapWholeWords" />
        </StackPanel>

        <Border Style="{StaticResource SearchSurfaceStyle}">
          <TextBox AutomationProperties.AutomationId="WorkbenchSearchInput"
                   Background="Transparent"
                   BorderThickness="0"
                   PlaceholderText="{Binding SearchPlaceholder}"
                   SelectionHighlightColor="{StaticResource AppAccentBrush}"
                   Text="{Binding RepositorySearchText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
        </Border>

        <Grid ColumnSpacing="12">
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="Auto" />
          </Grid.ColumnDefinitions>
          <TextBlock CharacterSpacing="80"
                     FontSize="11"
                     FontWeight="Medium"
                     Foreground="{StaticResource AppMutedTextBrush}"
                     Text="WORKSPACE TREE" />
          <TextBlock Grid.Column="1"
                     FontSize="11"
                     Foreground="{StaticResource AppMutedTextBrush}"
                     Text="{Binding RepositoryResultSummary}" />
        </Grid>

        <ScrollViewer AutomationProperties.AutomationId="RepositoryNodesList"
                      HorizontalScrollBarVisibility="Disabled"
                      VerticalScrollBarVisibility="Auto">
          <muxc:ItemsRepeater ItemsSource="{Binding FilteredRepositoryNodes}">
            <muxc:ItemsRepeater.ItemTemplate>
              <DataTemplate x:DataType="presentation:WorkbenchRepositoryNodeItem">
                <Grid Margin="0,0,0,8"
                      AutomationProperties.AutomationId="{x:Bind AutomationId}"
                      Tapped="OnRepositoryNodeTapped">
                  <Border Background="{StaticResource AppSoftSurfaceBrush}"
                          BorderBrush="{StaticResource AppOutlineBrush}"
                          BorderThickness="1"
                          CornerRadius="16"
                          Padding="12,10">
                    <Grid ColumnSpacing="10">
                      <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                      </Grid.ColumnDefinitions>
                      <TextBlock VerticalAlignment="Top"
                                 Margin="{x:Bind IndentMargin}"
                                 FontSize="12"
                                 Foreground="{StaticResource AppMutedTextBrush}"
                                 Text="{x:Bind KindGlyph}" />
                      <StackPanel Grid.Column="1"
                                  Spacing="2">
                        <TextBlock FontSize="13"
                                   FontWeight="SemiBold"
                                   Text="{x:Bind Name}" />
                        <TextBlock FontSize="11"
                                   Foreground="{StaticResource AppMutedTextBrush}"
                                   Text="{x:Bind DisplayLabel}"
                                   TextWrapping="WrapWholeWords" />
                      </StackPanel>
                    </Grid>
                  </Border>
                </Grid>
              </DataTemplate>
            </muxc:ItemsRepeater.ItemTemplate>
          </muxc:ItemsRepeater>
        </ScrollViewer>
      </StackPanel>

      <StackPanel Grid.Row="4">
        <Rectangle Margin="12,0,12,0"
                   Style="{StaticResource SectionDividerStyle}" />
        <Grid Margin="12,16,8,16"
              ColumnSpacing="10">
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="Auto" />
          </Grid.ColumnDefinitions>
          <Border Width="32"
                  Height="32"
                  Background="{StaticResource UserAvatarBrush}"
                  CornerRadius="16">
            <TextBlock HorizontalAlignment="Center"
                       VerticalAlignment="Center"
                       FontSize="12"
                       FontWeight="SemiBold"
                       Foreground="{StaticResource AppInputSurfaceBrush}"
                       Text="J" />
          </Border>
          <StackPanel Grid.Column="1"
                      Spacing="0">
            <TextBlock FontSize="12"
                       FontWeight="SemiBold"
                       Text="Jordan Lee" />
            <TextBlock FontSize="11"
                       Foreground="{StaticResource AppMutedTextBrush}"
                       Text="operator · active" />
          </StackPanel>
          <TextBlock Grid.Column="2"
                     VerticalAlignment="Center"
                     FontSize="16"
                     Foreground="{StaticResource AppMutedTextBrush}"
                     Text="⋯" />
        </Grid>
      </StackPanel>
    </Grid>
  </Border>
</UserControl>
