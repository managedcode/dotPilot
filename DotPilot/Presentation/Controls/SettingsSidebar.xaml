<UserControl x:Class="DotPilot.Presentation.Controls.SettingsSidebar"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:presentation="using:DotPilot.Presentation"
             xmlns:uen="using:Uno.Extensions.Navigation.UI"
             AutomationProperties.AutomationId="SettingsSidebar"
             FontFamily="{StaticResource AppBodyFontFamily}">
  <Border Style="{StaticResource GlassPanelStyle}"
          Padding="0">
    <Grid>
      <Grid.RowDefinitions>
        <RowDefinition Height="Auto" />
        <RowDefinition Height="Auto" />
        <RowDefinition Height="Auto" />
        <RowDefinition Height="*" />
        <RowDefinition Height="Auto" />
      </Grid.RowDefinitions>

      <StackPanel Margin="16,18,16,0"
                  Orientation="Horizontal"
                  Spacing="10">
        <Border Width="36"
                Height="36"
                Background="{StaticResource AppPrimaryTextBrush}"
                CornerRadius="11">
          <TextBlock HorizontalAlignment="Center"
                     VerticalAlignment="Center"
                     FontFamily="{StaticResource AppAccentFontFamily}"
                     FontSize="11"
                     Foreground="{StaticResource AppAccentBrush}"
                     Text="dp" />
        </Border>
        <TextBlock VerticalAlignment="Center"
                   FontSize="18"
                   FontWeight="SemiBold"
                   Foreground="{StaticResource AppPrimaryTextBrush}">
          <Run Text="dot" />
          <Run FontWeight="Normal"
               Foreground="{StaticResource AppMutedTextBrush}"
               Text="Pilot" />
        </TextBlock>
      </StackPanel>

      <StackPanel Grid.Row="1"
                  Margin="12,20,12,0"
                  Spacing="4">
        <Button AutomationProperties.AutomationId="SettingsSidebarChatButton"
                Style="{StaticResource SidebarButtonStyle}"
                uen:Navigation.Request="-/Main">
          <StackPanel Orientation="Horizontal"
                      Spacing="8">
            <TextBlock VerticalAlignment="Center"
                       FontSize="13"
                       Text="o" />
            <TextBlock VerticalAlignment="Center"
                       Text="Chat" />
          </StackPanel>
        </Button>
        <Button AutomationProperties.AutomationId="SettingsSidebarAgentsButton"
                Style="{StaticResource SidebarButtonStyle}"
                uen:Navigation.Request="Second">
          <StackPanel Orientation="Horizontal"
                      Spacing="8">
            <TextBlock VerticalAlignment="Center"
                       FontSize="13"
                       Text="*" />
            <TextBlock VerticalAlignment="Center"
                       Text="Agents" />
          </StackPanel>
        </Button>
        <Button AutomationProperties.AutomationId="SettingsSidebarSettingsButton"
                Style="{StaticResource SidebarButtonSelectedStyle}">
          <StackPanel Orientation="Horizontal"
                      Spacing="8">
            <TextBlock VerticalAlignment="Center"
                       FontSize="13"
                       Text="=" />
            <TextBlock VerticalAlignment="Center"
                       Text="Providers" />
          </StackPanel>
        </Button>
      </StackPanel>

      <Rectangle Grid.Row="2"
                 Margin="12,18,12,0"
                 Style="{StaticResource SectionDividerStyle}" />

      <StackPanel Grid.Row="3"
                  Margin="12,20,12,20"
                  Spacing="16">
        <StackPanel Spacing="4">
          <TextBlock FontSize="18"
                     FontWeight="SemiBold"
                     Text="Provider readiness" />
          <TextBlock FontSize="12"
                     Foreground="{StaticResource AppMutedTextBrush}"
                     Text="Enable the debug client or point the app at real local CLIs."
                     TextWrapping="WrapWholeWords" />
        </StackPanel>

        <ItemsControl AutomationProperties.AutomationId="SettingsSidebarProviders"
                      ItemsSource="{Binding Providers}">
          <ItemsControl.ItemTemplate>
            <DataTemplate x:DataType="presentation:ProviderStatusItem">
              <Border Background="{StaticResource AppSoftSurfaceBrush}"
                      BorderBrush="{StaticResource AppOutlineBrush}"
                      BorderThickness="1"
                      CornerRadius="16"
                      Margin="0,0,0,10"
                      Padding="12,10">
                <StackPanel Spacing="4">
                  <TextBlock FontSize="13"
                             FontWeight="SemiBold"
                             Text="{x:Bind DisplayName}" />
                  <TextBlock FontSize="11"
                             Foreground="{StaticResource AppMutedTextBrush}"
                             Text="{x:Bind StatusSummary}"
                             TextWrapping="WrapWholeWords" />
                </StackPanel>
              </Border>
            </DataTemplate>
          </ItemsControl.ItemTemplate>
        </ItemsControl>
      </StackPanel>

      <Rectangle Grid.Row="4"
                 VerticalAlignment="Top"
                 Margin="12,0,12,0"
                 Style="{StaticResource SectionDividerStyle}" />
      <Grid Grid.Row="4"
            Margin="12,16,8,16"
            ColumnSpacing="10">
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="Auto" />
          <ColumnDefinition Width="*" />
          <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>
        <Border Width="32"
                Height="32"
                Background="{StaticResource UserAvatarBrush}"
                CornerRadius="16">
          <TextBlock HorizontalAlignment="Center"
                     VerticalAlignment="Center"
                     FontSize="12"
                     FontWeight="SemiBold"
                     Foreground="{StaticResource AppInputSurfaceBrush}"
                     Text="P" />
        </Border>
        <StackPanel Grid.Column="1"
                    Spacing="0">
          <TextBlock FontSize="12"
                     FontWeight="SemiBold"
                     Text="Provider operator" />
          <TextBlock FontSize="11"
                     Foreground="{StaticResource AppMutedTextBrush}"
                     Text="local readiness" />
        </StackPanel>
        <TextBlock Grid.Column="2"
                   VerticalAlignment="Center"
                   FontSize="16"
                   Foreground="{StaticResource AppMutedTextBrush}"
                   Text="..." />
      </Grid>
    </Grid>
  </Border>
</UserControl>
