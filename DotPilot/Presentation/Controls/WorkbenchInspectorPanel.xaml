<UserControl x:Class="DotPilot.Presentation.Controls.WorkbenchInspectorPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="using:DotPilot.Presentation.Controls"
             xmlns:workbench="using:DotPilot.Core.Features.Workbench"
             AutomationProperties.AutomationId="WorkbenchInspectorPanel">
  <Border Style="{StaticResource GlassPanelStyle}"
          Padding="0">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
      <StackPanel Margin="16"
                  Spacing="16">
        <Grid ColumnSpacing="12">
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="Auto" />
          </Grid.ColumnDefinitions>
          <StackPanel Spacing="4">
            <TextBlock CharacterSpacing="80"
                       FontSize="11"
                       FontWeight="Medium"
                       Foreground="{StaticResource AppMutedTextBrush}"
                       Text="INSPECTOR" />
            <TextBlock AutomationProperties.AutomationId="InspectorTitle"
                       FontSize="18"
                       FontWeight="SemiBold"
                       Text="{Binding InspectorTitle}" />
            <TextBlock FontSize="12"
                       Foreground="{StaticResource AppMutedTextBrush}"
                       Text="{Binding InspectorSummary}"
                       TextWrapping="WrapWholeWords" />
          </StackPanel>
          <ToggleSwitch Grid.Column="1"
                        AutomationProperties.AutomationId="InspectorModeToggle"
                        Header="Log console"
                        IsOn="{Binding IsLogConsoleVisible, Mode=TwoWay}"
                        OffContent="Artifacts"
                        OnContent="Logs" />
        </Grid>

        <ItemsControl AutomationProperties.AutomationId="ArtifactDockList"
                      ItemsSource="{Binding Artifacts}"
                      Visibility="{Binding IsArtifactsVisible}">
          <ItemsControl.ItemTemplate>
            <DataTemplate x:DataType="workbench:WorkbenchArtifactDescriptor">
              <Border Background="{StaticResource AppSoftSurfaceBrush}"
                      BorderBrush="{StaticResource AppOutlineBrush}"
                      BorderThickness="1"
                      CornerRadius="16"
                      Margin="0,0,0,10"
                      Padding="12,10">
                <Grid AutomationProperties.AutomationId="ArtifactDockItem"
                      ColumnSpacing="10">
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                  </Grid.ColumnDefinitions>
                  <StackPanel Spacing="4">
                    <TextBlock FontSize="13"
                               FontWeight="SemiBold"
                               Text="{x:Bind Name}" />
                    <TextBlock FontSize="12"
                               Foreground="{StaticResource AppMutedTextBrush}"
                               Text="{x:Bind Summary}"
                               TextWrapping="WrapWholeWords" />
                    <TextBlock FontSize="11"
                               Foreground="{StaticResource AppSecondaryTextBrush}"
                               Text="{x:Bind RelativePath}" />
                  </StackPanel>
                  <Border Grid.Column="1"
                          Background="{StaticResource AppBadgeSurfaceBrush}"
                          CornerRadius="100"
                          Padding="10,4"
                          VerticalAlignment="Top">
                    <TextBlock FontSize="10"
                               Foreground="{StaticResource AppPrimaryTextBrush}"
                               Text="{x:Bind Status}" />
                  </Border>
                </Grid>
              </Border>
            </DataTemplate>
          </ItemsControl.ItemTemplate>
        </ItemsControl>

        <ItemsControl AutomationProperties.AutomationId="RuntimeLogList"
                      ItemsSource="{Binding Logs}"
                      Visibility="{Binding IsLogConsoleVisible}">
          <ItemsControl.ItemTemplate>
            <DataTemplate x:DataType="workbench:WorkbenchLogEntry">
              <Border Background="{StaticResource AppSoftSurfaceBrush}"
                      BorderBrush="{StaticResource AppOutlineBrush}"
                      BorderThickness="1"
                      CornerRadius="16"
                      Margin="0,0,0,10"
                      Padding="12,10">
                <StackPanel AutomationProperties.AutomationId="RuntimeLogItem"
                            Spacing="6">
                  <Grid ColumnSpacing="10">
                    <Grid.ColumnDefinitions>
                      <ColumnDefinition Width="Auto" />
                      <ColumnDefinition Width="Auto" />
                      <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <TextBlock FontSize="11"
                               Foreground="{StaticResource AppMutedTextBrush}"
                               Text="{x:Bind Timestamp}" />
                    <TextBlock Grid.Column="1"
                               FontSize="11"
                               Foreground="{StaticResource AppSecondaryTextBrush}"
                               Text="{x:Bind Level}" />
                    <TextBlock Grid.Column="2"
                               FontSize="11"
                               Foreground="{StaticResource AppSecondaryTextBrush}"
                               Text="{x:Bind Source}" />
                  </Grid>
                  <TextBlock FontSize="12"
                             Text="{x:Bind Message}"
                             TextWrapping="WrapWholeWords" />
                </StackPanel>
              </Border>
            </DataTemplate>
          </ItemsControl.ItemTemplate>
        </ItemsControl>

        <Rectangle Style="{StaticResource SectionDividerStyle}" />

        <controls:RuntimeFoundationPanel DataContext="{Binding RuntimeFoundation}" />
      </StackPanel>
    </ScrollViewer>
  </Border>
</UserControl>
