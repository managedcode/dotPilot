<UserControl x:Class="DotPilot.Presentation.Controls.SettingsShell"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:presentation="using:DotPilot.Presentation"
             xmlns:controls="using:DotPilot.Presentation.Controls"
             xmlns:workbench="using:DotPilot.Core.Features.Workbench"
             AutomationProperties.AutomationId="SettingsShell">
  <Grid RowSpacing="16">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
    </Grid.RowDefinitions>

    <Border Style="{StaticResource GlassPanelStyle}">
      <StackPanel Spacing="8">
        <TextBlock CharacterSpacing="80"
                   FontSize="11"
                   FontWeight="Medium"
                   Foreground="{StaticResource AppMutedTextBrush}"
                   Text="{Binding SettingsIssueLabel}" />
        <TextBlock FontSize="24"
                   FontWeight="SemiBold"
                   Text="{Binding PageTitle}" />
        <TextBlock FontSize="13"
                   Foreground="{StaticResource AppMutedTextBrush}"
                   Text="{Binding PageSubtitle}"
                   TextWrapping="WrapWholeWords" />
      </StackPanel>
    </Border>

    <Grid Grid.Row="1"
          ColumnSpacing="20">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="320" />
        <ColumnDefinition Width="*" />
      </Grid.ColumnDefinitions>

      <Border Style="{StaticResource GlassPanelStyle}">
        <StackPanel Spacing="14">
          <TextBlock CharacterSpacing="80"
                     FontSize="11"
                     FontWeight="Medium"
                     Foreground="{StaticResource AppMutedTextBrush}"
                     Text="CATEGORIES" />
          <ListView AutomationProperties.AutomationId="SettingsCategoryList"
                    Background="Transparent"
                    BorderBrush="Transparent"
                    BorderThickness="0"
                    ItemsSource="{Binding Categories}"
                    SelectedItem="{Binding SelectedCategory, Mode=TwoWay}"
                    SelectionMode="Single">
            <ListView.ItemTemplate>
              <DataTemplate x:DataType="presentation:WorkbenchSettingsCategoryItem">
                <Border Background="{StaticResource AppSoftSurfaceBrush}"
                        BorderBrush="{StaticResource AppOutlineBrush}"
                        BorderThickness="1"
                        CornerRadius="16"
                        Margin="0,0,0,10"
                        Padding="12,10"
                        AutomationProperties.AutomationId="{x:Bind AutomationId}">
                  <StackPanel Spacing="4">
                    <TextBlock FontSize="13"
                               FontWeight="SemiBold"
                               Text="{x:Bind Title}" />
                    <TextBlock FontSize="11"
                               Foreground="{StaticResource AppMutedTextBrush}"
                               Text="{x:Bind Summary}"
                               TextWrapping="WrapWholeWords" />
                  </StackPanel>
                </Border>
              </DataTemplate>
            </ListView.ItemTemplate>
          </ListView>
        </StackPanel>
      </Border>

      <Border Grid.Column="1"
              Style="{StaticResource GlassPanelStyle}">
        <StackPanel Spacing="16">
          <Grid ColumnSpacing="12">
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="*" />
              <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <StackPanel Spacing="4">
              <TextBlock AutomationProperties.AutomationId="SelectedSettingsCategoryTitle"
                         FontSize="20"
                         FontWeight="SemiBold"
                         Text="{Binding SelectedCategoryTitle}" />
              <TextBlock FontSize="12"
                         Foreground="{StaticResource AppMutedTextBrush}"
                         Text="{Binding SelectedCategorySummary}"
                         TextWrapping="WrapWholeWords" />
            </StackPanel>
            <Border Grid.Column="1"
                    Background="{StaticResource AppAccentBrush}"
                    CornerRadius="100"
                    Padding="12,6"
                    VerticalAlignment="Top">
              <TextBlock FontSize="11"
                         Foreground="{StaticResource AppPrimaryTextBrush}"
                         Text="{Binding ProviderSummary}" />
            </Border>
          </Grid>

          <Rectangle Style="{StaticResource SectionDividerStyle}" />

          <controls:ToolchainCenterPanel Visibility="{Binding IsToolchainCenterVisible}" />

          <ItemsControl AutomationProperties.AutomationId="SettingsEntriesList"
                        ItemsSource="{Binding VisibleEntries}"
                        Visibility="{Binding AreGenericSettingsVisible}">
            <ItemsControl.ItemTemplate>
              <DataTemplate x:DataType="workbench:WorkbenchSettingEntry">
                <Border Background="{StaticResource AppSoftSurfaceBrush}"
                        BorderBrush="{StaticResource AppOutlineBrush}"
                        BorderThickness="1"
                        CornerRadius="16"
                        Margin="0,0,0,10"
                        Padding="14,12">
                  <Grid AutomationProperties.AutomationId="SettingsEntryItem"
                        ColumnSpacing="12">
                    <Grid.ColumnDefinitions>
                      <ColumnDefinition Width="*" />
                      <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Spacing="4">
                      <TextBlock FontSize="13"
                                 FontWeight="SemiBold"
                                 Text="{x:Bind Name}" />
                      <TextBlock FontSize="12"
                                 Text="{x:Bind Value}" />
                      <TextBlock FontSize="11"
                                 Foreground="{StaticResource AppMutedTextBrush}"
                                 Text="{x:Bind Summary}"
                                 TextWrapping="WrapWholeWords" />
                    </StackPanel>
                    <Border Grid.Column="1"
                            Background="{StaticResource AppBadgeSurfaceBrush}"
                            CornerRadius="100"
                            Padding="10,4"
                            VerticalAlignment="Top">
                      <TextBlock FontSize="10"
                                 Foreground="{StaticResource AppPrimaryTextBrush}"
                                 Text="{x:Bind IsActionable}" />
                    </Border>
                  </Grid>
                </Border>
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>
        </StackPanel>
      </Border>
    </Grid>
  </Grid>
</UserControl>
