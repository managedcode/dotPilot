<UserControl x:Class="DotPilot.Presentation.Controls.SettingsShell"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:presentation="using:DotPilot.Presentation"
             x:Name="Root"
             AutomationProperties.AutomationId="SettingsShell">
  <Grid RowSpacing="16">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
    </Grid.RowDefinitions>

    <Border Style="{StaticResource GlassPanelStyle}">
      <StackPanel Spacing="8">
        <TextBlock FontSize="24"
                   FontWeight="SemiBold"
                   Text="{Binding PageTitle}" />
        <TextBlock FontSize="13"
                   Foreground="{StaticResource AppMutedTextBrush}"
                   Text="{Binding PageSubtitle}"
                   TextWrapping="WrapWholeWords" />
      </StackPanel>
    </Border>

    <Grid Grid.Row="1"
          ColumnSpacing="20">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="320" />
        <ColumnDefinition Width="*" />
      </Grid.ColumnDefinitions>

      <Border Style="{StaticResource GlassPanelStyle}">
        <StackPanel Spacing="14">
          <TextBlock CharacterSpacing="80"
                     FontSize="11"
                     FontWeight="Medium"
                     Foreground="{StaticResource AppMutedTextBrush}"
                     Text="PROVIDERS" />
          <ListView AutomationProperties.AutomationId="ProviderList"
                    Background="Transparent"
                    BorderBrush="Transparent"
                    BorderThickness="0"
                    ItemsSource="{Binding Providers}"
                    SelectedItem="{Binding SelectedProvider, Mode=TwoWay}"
                    SelectionMode="Single">
            <ListView.ItemTemplate>
              <DataTemplate x:DataType="presentation:ProviderStatusItem">
                <Border Background="{StaticResource AppSoftSurfaceBrush}"
                        BorderBrush="{StaticResource AppOutlineBrush}"
                        BorderThickness="1"
                        CornerRadius="16"
                        Margin="0,0,0,10"
                        Padding="12,10"
                        AutomationProperties.AutomationId="ProviderEntryItem">
                  <StackPanel Spacing="4">
                    <TextBlock FontSize="13"
                               FontWeight="SemiBold"
                               Text="{x:Bind DisplayName}" />
                    <TextBlock FontSize="11"
                               Foreground="{StaticResource AppMutedTextBrush}"
                               Text="{x:Bind StatusSummary}"
                               TextWrapping="WrapWholeWords" />
                  </StackPanel>
                </Border>
              </DataTemplate>
            </ListView.ItemTemplate>
          </ListView>
        </StackPanel>
      </Border>

      <Border Grid.Column="1"
              Style="{StaticResource GlassPanelStyle}">
        <StackPanel Spacing="16">
          <Grid ColumnSpacing="12">
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="*" />
              <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <StackPanel Spacing="4">
              <TextBlock AutomationProperties.AutomationId="SelectedProviderTitle"
                         FontSize="20"
                         FontWeight="SemiBold"
                         Text="{Binding SelectedProviderTitle}" />
              <TextBlock FontSize="12"
                         Foreground="{StaticResource AppMutedTextBrush}"
                         Text="{Binding SelectedProviderSummary}"
                         TextWrapping="WrapWholeWords" />
            </StackPanel>
            <Border Grid.Column="1"
                    Background="{StaticResource AppAccentBrush}"
                    CornerRadius="100"
                    Padding="12,6"
                    VerticalAlignment="Top">
              <TextBlock FontSize="11"
                         Foreground="{StaticResource AppPrimaryTextBrush}"
                         Text="{Binding ToggleActionLabel}" />
            </Border>
          </Grid>

          <Rectangle Style="{StaticResource SectionDividerStyle}" />

          <Border Background="{StaticResource AppSoftSurfaceBrush}"
                  BorderBrush="{StaticResource AppOutlineBrush}"
                  BorderThickness="1"
                  CornerRadius="16"
                  Padding="14,12">
            <StackPanel Spacing="10">
              <TextBlock FontSize="12"
                         FontWeight="Medium"
                         Text="Suggested command" />
              <TextBlock AutomationProperties.AutomationId="SelectedProviderInstallCommand"
                         FontSize="12"
                         FontFamily="{StaticResource AppAccentFontFamily}"
                         Foreground="{StaticResource AppMutedTextBrush}"
                         Text="{Binding SelectedProviderInstallCommand}"
                         TextWrapping="WrapWholeWords" />
            </StackPanel>
          </Border>

          <StackPanel Spacing="10"
                      Visibility="{Binding HasSelectedProviderActions}">
            <TextBlock FontSize="12"
                       FontWeight="Medium"
                       Text="Provider actions" />
            <ItemsControl ItemsSource="{Binding SelectedProviderActions}">
              <ItemsControl.ItemTemplate>
                <DataTemplate x:DataType="presentation:ProviderActionItem">
                  <Border Background="{StaticResource AppSoftSurfaceBrush}"
                          BorderBrush="{StaticResource AppOutlineBrush}"
                          BorderThickness="1"
                          CornerRadius="16"
                          Margin="0,0,0,10"
                          Padding="12,10">
                    <Grid ColumnSpacing="12">
                      <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                      </Grid.ColumnDefinitions>
                      <StackPanel Spacing="4">
                        <TextBlock FontSize="13"
                                   FontWeight="SemiBold"
                                   Text="{x:Bind Label}" />
                        <TextBlock FontSize="11"
                                   Foreground="{StaticResource AppMutedTextBrush}"
                                   Text="{x:Bind Summary}"
                                   TextWrapping="WrapWholeWords" />
                      </StackPanel>
                      <Button Grid.Column="1"
                              AutomationProperties.AutomationId="ProviderActionButton"
                              Background="{StaticResource AppSoftSurfaceBrush}"
                              BorderBrush="{StaticResource AppOutlineBrush}"
                              BorderThickness="1"
                              Command="{Binding DataContext.ExecuteProviderAction, ElementName=Root}"
                              CommandParameter="{Binding}"
                              CornerRadius="16"
                              Padding="14,9"
                              VerticalAlignment="Center">
                        <TextBlock FontSize="12"
                                   FontWeight="SemiBold"
                                   Text="Copy command" />
                      </Button>
                    </Grid>
                  </Border>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>
          </StackPanel>

          <Grid ColumnSpacing="12">
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="Auto" />
              <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <Button AutomationProperties.AutomationId="ToggleProviderButton"
                    Background="{StaticResource AppAccentBrush}"
                    BorderBrush="Transparent"
                    BorderThickness="0"
                    Command="{Binding ToggleSelectedProvider}"
                    IsEnabled="{Binding CanToggleSelectedProvider}"
                    CornerRadius="18"
                    Padding="16,10">
              <TextBlock FontSize="12"
                         FontWeight="SemiBold"
                         Foreground="{StaticResource AppPrimaryTextBrush}"
                         Text="{Binding ToggleActionLabel}" />
            </Button>

            <Button Grid.Column="1"
                    AutomationProperties.AutomationId="RefreshProvidersButton"
                    Background="{StaticResource AppSoftSurfaceBrush}"
                    BorderBrush="{StaticResource AppOutlineBrush}"
                    BorderThickness="1"
                    Command="{Binding Refresh}"
                    CornerRadius="18"
                    Padding="16,10">
              <TextBlock FontSize="12"
                         FontWeight="SemiBold"
                         Text="Refresh" />
            </Button>
          </Grid>

          <TextBlock AutomationProperties.AutomationId="ProviderStatusMessage"
                     FontSize="12"
                     Foreground="{StaticResource AppMutedTextBrush}"
                     Text="{Binding StatusMessage}"
                     TextWrapping="WrapWholeWords" />
        </StackPanel>
      </Border>
    </Grid>
  </Grid>
</UserControl>
