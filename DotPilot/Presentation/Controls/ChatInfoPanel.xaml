<UserControl x:Class="DotPilot.Presentation.Controls.ChatInfoPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:uen="using:Uno.Extensions.Navigation.UI"
             xmlns:presentation="using:DotPilot.Presentation"
             AutomationProperties.AutomationId="ChatInfoPanel">
  <UserControl.Resources>
    <DataTemplate x:Key="MemberTemplate"
                  x:DataType="presentation:ParticipantItem">
      <Grid Margin="0,0,0,10"
            AutomationProperties.AutomationId="ChatMemberItem"
            ColumnSpacing="10">
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="Auto" />
          <ColumnDefinition Width="*" />
          <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>

        <Border Width="32"
                Height="32"
                Background="{x:Bind AvatarBrush}"
                CornerRadius="16">
          <TextBlock HorizontalAlignment="Center"
                     VerticalAlignment="Center"
                     FontSize="12"
                     FontWeight="Bold"
                     Foreground="White"
                     Text="{x:Bind Initial}" />
        </Border>

        <StackPanel Grid.Column="1"
                    VerticalAlignment="Center"
                    Spacing="1">
          <TextBlock FontSize="14"
                     FontWeight="Medium"
                     Foreground="{StaticResource AppPrimaryTextBrush}"
                     Text="{x:Bind Name}" />
          <TextBlock FontSize="12"
                     Foreground="{StaticResource AppMutedTextBrush}"
                     Text="{x:Bind SecondaryText}" />
        </StackPanel>

        <Border Grid.Column="2"
                VerticalAlignment="Center"
                Background="{x:Bind BadgeBrush}"
                CornerRadius="100"
                Padding="8,2">
          <TextBlock FontSize="10"
                     Foreground="{StaticResource AppPrimaryTextBrush}"
                     Text="{x:Bind BadgeText}" />
        </Border>
      </Grid>
    </DataTemplate>

    <DataTemplate x:Key="AgentTemplate"
                  x:DataType="presentation:ParticipantItem">
      <Grid Margin="0,0,0,10"
            AutomationProperties.AutomationId="ChatAgentItem"
            ColumnSpacing="10">
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="Auto" />
          <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Border Width="32"
                Height="32"
                Background="{x:Bind AvatarBrush}"
                CornerRadius="16">
          <TextBlock HorizontalAlignment="Center"
                     VerticalAlignment="Center"
                     FontSize="12"
                     FontWeight="Bold"
                     Foreground="White"
                     Text="{x:Bind Initial}" />
        </Border>

        <StackPanel Grid.Column="1"
                    VerticalAlignment="Center"
                    Spacing="1">
          <TextBlock FontSize="14"
                     FontWeight="Medium"
                     Foreground="{StaticResource AppPrimaryTextBrush}"
                     Text="{x:Bind Name}" />
          <TextBlock FontSize="12"
                     Foreground="{StaticResource AppMutedTextBrush}"
                     Text="{x:Bind SecondaryText}" />
        </StackPanel>
      </Grid>
    </DataTemplate>
  </UserControl.Resources>

  <Border Style="{StaticResource GlassPanelStyle}"
          Padding="0">
    <Grid>
      <Grid.RowDefinitions>
        <RowDefinition Height="Auto" />
        <RowDefinition Height="*" />
      </Grid.RowDefinitions>

      <Grid Margin="20,16,16,12"
            AutomationProperties.AutomationId="ChatInfoPanelHeader"
            ColumnSpacing="12">
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="*" />
          <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>

        <TextBlock FontSize="15"
                   FontWeight="Medium"
                   Foreground="{StaticResource AppPrimaryTextBrush}"
                   Text="Chat Information" />

        <Button Grid.Column="1"
                AutomationProperties.AutomationId="ChatInfoPanelCloseButton"
                Background="Transparent"
                BorderBrush="Transparent"
                BorderThickness="0"
                Padding="4">
          <TextBlock FontSize="14"
                     Foreground="{StaticResource AppMutedTextBrush}"
                     Text="x" />
        </Button>
      </Grid>

      <ScrollViewer Grid.Row="1"
                    VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="20,0,20,20"
                    AutomationProperties.AutomationId="ChatInfoPanelContent"
                    Spacing="20">
          <StackPanel Spacing="4">
            <TextBlock CharacterSpacing="80"
                       FontSize="12"
                       FontWeight="Medium"
                       Foreground="{StaticResource AppMutedTextBrush}"
                       Text="CHAT NAME" />
            <TextBlock FontSize="14"
                       FontWeight="Medium"
                       Foreground="{StaticResource AppPrimaryTextBrush}"
                       Text="{Binding Title}" />
          </StackPanel>

          <Rectangle Style="{StaticResource SectionDividerStyle}" />

          <StackPanel Spacing="8">
            <Button AutomationProperties.AutomationId="ChatFilesButton"
                    Background="Transparent"
                    BorderBrush="Transparent"
                    BorderThickness="0"
                    Padding="0">
              <Grid Padding="0,10"
                    ColumnSpacing="8">
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="Auto" />
                  <ColumnDefinition Width="*" />
                  <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock VerticalAlignment="Center"
                           FontSize="12"
                           Text="[]" />
                <TextBlock Grid.Column="1"
                           VerticalAlignment="Center"
                           FontSize="14"
                           FontWeight="Medium"
                           Text="Files" />
                <TextBlock Grid.Column="2"
                           VerticalAlignment="Center"
                           FontSize="14"
                           Foreground="{StaticResource AppMutedTextBrush}"
                           Text=">" />
              </Grid>
            </Button>

            <Button AutomationProperties.AutomationId="ChatPhotosButton"
                    Background="Transparent"
                    BorderBrush="Transparent"
                    BorderThickness="0"
                    Padding="0">
              <Grid Padding="0,10"
                    ColumnSpacing="8">
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="Auto" />
                  <ColumnDefinition Width="*" />
                  <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock VerticalAlignment="Center"
                           FontSize="12"
                           Text="o" />
                <TextBlock Grid.Column="1"
                           VerticalAlignment="Center"
                           FontSize="14"
                           FontWeight="Medium"
                           Text="Photos" />
                <TextBlock Grid.Column="2"
                           VerticalAlignment="Center"
                           FontSize="14"
                           Foreground="{StaticResource AppMutedTextBrush}"
                           Text=">" />
              </Grid>
            </Button>
          </StackPanel>

          <Rectangle Style="{StaticResource SectionDividerStyle}" />

          <StackPanel Spacing="12">
            <Grid ColumnSpacing="12">
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
              </Grid.ColumnDefinitions>

              <TextBlock CharacterSpacing="80"
                         FontSize="12"
                         FontWeight="Medium"
                         Foreground="{StaticResource AppMutedTextBrush}"
                         Text="MEMBERS" />

              <Button Grid.Column="1"
                      AutomationProperties.AutomationId="ChatAddMemberButton"
                      Background="{StaticResource AppSoftSurfaceBrush}"
                      BorderBrush="{StaticResource AppOutlineBrush}"
                      BorderThickness="1"
                      CornerRadius="100"
                      Padding="8,4">
                <StackPanel Orientation="Horizontal"
                            Spacing="4">
                  <TextBlock FontSize="11"
                             Text="+" />
                  <TextBlock FontSize="11"
                             FontWeight="Medium"
                             Text="Add member" />
                </StackPanel>
              </Button>
            </Grid>

            <ItemsControl AutomationProperties.AutomationId="ChatMembersList"
                          ItemTemplate="{StaticResource MemberTemplate}"
                          ItemsSource="{Binding Members}" />
          </StackPanel>

          <Rectangle Style="{StaticResource SectionDividerStyle}" />

          <StackPanel Spacing="12">
            <Grid ColumnSpacing="12">
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
              </Grid.ColumnDefinitions>

              <TextBlock CharacterSpacing="80"
                         FontSize="12"
                         FontWeight="Medium"
                         Foreground="{StaticResource AppMutedTextBrush}"
                         Text="AGENTS" />

              <Button Grid.Column="1"
                      AutomationProperties.AutomationId="ChatAddAgentButton"
                      Background="{StaticResource AppSoftSurfaceBrush}"
                      BorderBrush="{StaticResource AppOutlineBrush}"
                      BorderThickness="1"
                      CornerRadius="100"
                      Padding="8,4"
                      uen:Navigation.Request="Second">
                <StackPanel Orientation="Horizontal"
                            Spacing="4">
                  <TextBlock FontSize="11"
                             Text="+" />
                  <TextBlock FontSize="11"
                             FontWeight="Medium"
                             Text="Add agent" />
                </StackPanel>
              </Button>
            </Grid>

            <ItemsControl AutomationProperties.AutomationId="ChatAgentsList"
                          ItemTemplate="{StaticResource AgentTemplate}"
                          ItemsSource="{Binding Agents}" />
          </StackPanel>
        </StackPanel>
      </ScrollViewer>
    </Grid>
  </Border>
</UserControl>
