<UserControl x:Class="DotPilot.Presentation.Controls.ChatConversationView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="using:DotPilot.Presentation.Controls"
             xmlns:presentation="using:DotPilot.Presentation"
             AutomationProperties.AutomationId="ChatConversationView">
  <UserControl.Resources>
    <DataTemplate x:Key="IncomingMessageTemplate"
                  x:DataType="presentation:ChatMessageItem">
      <Grid Margin="0,0,0,22"
            MaxWidth="660">
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="Auto" />
          <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Border Width="32"
                Height="32"
                VerticalAlignment="Top"
                Background="{x:Bind AvatarBrush}"
                CornerRadius="16">
          <TextBlock HorizontalAlignment="Center"
                     VerticalAlignment="Center"
                     FontSize="12"
                     FontWeight="Bold"
                     Foreground="White"
                     Text="{x:Bind Initial}" />
        </Border>

        <StackPanel Grid.Column="1"
                    Margin="10,0,0,0"
                    MaxWidth="600"
                    Spacing="9">
          <StackPanel Orientation="Horizontal"
                      Spacing="8">
            <TextBlock FontSize="12"
                       FontWeight="SemiBold"
                       Foreground="{StaticResource AppSecondaryTextBrush}"
                       Text="{x:Bind Author}" />
            <TextBlock FontSize="10"
                       Foreground="{StaticResource AppMutedTextBrush}"
                       Text="{x:Bind Timestamp}" />
          </StackPanel>

          <Border Background="{StaticResource AppSoftSurfaceBrush}"
                  BorderBrush="{StaticResource AppOutlineBrush}"
                  BorderThickness="1"
                  CornerRadius="18,18,18,6"
                  Padding="16,14">
            <TextBlock FontSize="14"
                       Foreground="{StaticResource AppPrimaryTextBrush}"
                       LineHeight="22"
                       Text="{x:Bind Content}"
                       TextWrapping="Wrap" />
          </Border>
        </StackPanel>
      </Grid>
    </DataTemplate>

    <DataTemplate x:Key="OutgoingMessageTemplate"
                  x:DataType="presentation:ChatMessageItem">
      <StackPanel Margin="0,0,0,22"
                  HorizontalAlignment="Right"
                  MaxWidth="620"
                  Spacing="6">
        <StackPanel HorizontalAlignment="Right"
                    Orientation="Horizontal"
                    Spacing="8">
          <TextBlock FontSize="10"
                     Foreground="{StaticResource AppMutedTextBrush}"
                     Text="{x:Bind Timestamp}" />
          <TextBlock FontSize="12"
                     FontWeight="SemiBold"
                     Foreground="{StaticResource AppSecondaryTextBrush}"
                     Text="{x:Bind Author}" />
        </StackPanel>

        <Border Background="{StaticResource AppDarkSurfaceBrush}"
                CornerRadius="28,28,8,28"
                Padding="16">
          <TextBlock FontSize="14"
                     Foreground="White"
                     LineHeight="22"
                     Text="{x:Bind Content}"
                     TextWrapping="Wrap" />
        </Border>
      </StackPanel>
    </DataTemplate>

    <controls:ChatMessageTemplateSelector x:Key="ChatMessageTemplateSelector"
                                          IncomingTemplate="{StaticResource IncomingMessageTemplate}"
                                          OutgoingTemplate="{StaticResource OutgoingMessageTemplate}" />
  </UserControl.Resources>

  <Grid>
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
    </Grid.RowDefinitions>

    <Grid Margin="0,8,0,0"
          AutomationProperties.AutomationId="ChatConversationHeader"
          ColumnSpacing="12">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="Auto" />
        <ColumnDefinition Width="*" />
        <ColumnDefinition Width="Auto" />
      </Grid.ColumnDefinitions>

      <Border Width="40"
              Height="40"
              Background="{StaticResource DesignAvatarBrush}"
              CornerRadius="20">
        <TextBlock HorizontalAlignment="Center"
                   VerticalAlignment="Center"
                   FontSize="15"
                   FontWeight="Bold"
                   Foreground="White"
                   Text="D" />
      </Border>

      <StackPanel Grid.Column="1"
                  Spacing="2">
        <TextBlock FontSize="16"
                   FontWeight="SemiBold"
                   Foreground="{StaticResource AppPrimaryTextBrush}"
                   Text="{Binding Title}" />
        <StackPanel Orientation="Horizontal"
                    Spacing="6">
          <Ellipse Width="7"
                   Height="7"
                   Fill="{StaticResource AppSuccessBrush}" />
          <TextBlock FontSize="12"
                     Foreground="{StaticResource AppMutedTextBrush}"
                     Text="{Binding StatusSummary}" />
        </StackPanel>
      </StackPanel>

      <Button Grid.Column="2"
              AutomationProperties.AutomationId="ChatShareButton"
              Background="{StaticResource AppSoftSurfaceBrush}"
              BorderBrush="{StaticResource AppOutlineBrush}"
              BorderThickness="1"
              CornerRadius="20"
              Padding="14,10">
        <StackPanel Orientation="Horizontal"
                    Spacing="6">
          <TextBlock FontSize="11"
                     Text="+" />
          <TextBlock FontSize="12"
                     FontWeight="SemiBold"
                     Text="Share" />
        </StackPanel>
      </Button>
    </Grid>

    <ScrollViewer Grid.Row="1"
                  Margin="0,24,0,0"
                  VerticalScrollBarVisibility="Auto">
      <StackPanel AutomationProperties.AutomationId="ChatMessagesRegion"
                  Spacing="24">
        <TextBlock HorizontalAlignment="Center"
                   CharacterSpacing="40"
                   FontSize="12"
                   FontWeight="Medium"
                   Foreground="{StaticResource AppMutedTextBrush}"
                   Text="Today - March 11" />

        <ItemsControl AutomationProperties.AutomationId="ChatMessagesList"
                      ItemTemplateSelector="{StaticResource ChatMessageTemplateSelector}"
                      ItemsSource="{Binding Messages}" />
      </StackPanel>
    </ScrollViewer>
  </Grid>
</UserControl>
