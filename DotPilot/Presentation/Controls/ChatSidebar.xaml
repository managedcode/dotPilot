<UserControl x:Class="DotPilot.Presentation.Controls.ChatSidebar"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:uen="using:Uno.Extensions.Navigation.UI"
             xmlns:presentation="using:DotPilot.Presentation"
             AutomationProperties.AutomationId="ChatSidebar">
  <Border Style="{StaticResource GlassPanelStyle}"
          Padding="0">
    <Grid>
      <Grid.RowDefinitions>
        <RowDefinition Height="Auto" />
        <RowDefinition Height="Auto" />
        <RowDefinition Height="Auto" />
        <RowDefinition Height="*" />
        <RowDefinition Height="Auto" />
      </Grid.RowDefinitions>

      <StackPanel Margin="16,18,16,0"
                  AutomationProperties.AutomationId="ChatSidebarBrand"
                  Orientation="Horizontal"
                  Spacing="10">
        <Border Width="36"
                Height="36"
                Background="{StaticResource AppPrimaryTextBrush}"
                CornerRadius="11">
          <TextBlock HorizontalAlignment="Center"
                     VerticalAlignment="Center"
                     FontFamily="{StaticResource AppAccentFontFamily}"
                     FontSize="11"
                     Foreground="{StaticResource AppAccentBrush}"
                     Text="dp" />
        </Border>
        <TextBlock VerticalAlignment="Center"
                   FontSize="18"
                   FontWeight="SemiBold"
                   Foreground="{StaticResource AppPrimaryTextBrush}">
          <Run Text="dot" />
          <Run FontWeight="Normal"
               Foreground="{StaticResource AppMutedTextBrush}"
               Text="Pilot" />
        </TextBlock>
      </StackPanel>

      <StackPanel Grid.Row="1"
                  Margin="12,20,12,0"
                  AutomationProperties.AutomationId="ChatSidebarNavigation"
                  Spacing="4">
        <Button AutomationProperties.AutomationId="ChatNavButton"
                Style="{StaticResource SidebarButtonSelectedStyle}">
          <StackPanel Orientation="Horizontal"
                      Spacing="8">
            <TextBlock VerticalAlignment="Center"
                       FontSize="13"
                       Text="o" />
            <TextBlock VerticalAlignment="Center"
                       Text="Chat" />
          </StackPanel>
        </Button>
        <Button AutomationProperties.AutomationId="AgentsNavButton"
                Style="{StaticResource SidebarButtonStyle}"
                uen:Navigation.Request="Second">
          <StackPanel Orientation="Horizontal"
                      Spacing="8">
            <TextBlock VerticalAlignment="Center"
                       FontSize="13"
                       Text="*" />
            <TextBlock VerticalAlignment="Center"
                       Text="Agents" />
          </StackPanel>
        </Button>
      </StackPanel>

      <Rectangle Grid.Row="2"
                 Margin="12,18,12,0"
                 Style="{StaticResource SectionDividerStyle}" />

      <ScrollViewer Grid.Row="3"
                    Margin="0"
                    VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="12,20,12,20"
                    AutomationProperties.AutomationId="ChatSidebarContent"
                    Spacing="16">
          <TextBlock Margin="12,0,0,0"
                     CharacterSpacing="80"
                     FontSize="12"
                     FontWeight="Medium"
                     Foreground="{StaticResource AppMutedTextBrush}"
                     Text="RECENT CHATS" />

          <Border AutomationProperties.AutomationId="ChatSearchSurface"
                  Style="{StaticResource SearchSurfaceStyle}">
            <StackPanel Orientation="Horizontal"
                        Spacing="8">
              <TextBlock FontSize="12"
                         Foreground="{StaticResource AppMutedTextBrush}"
                         Text="?" />
              <TextBlock FontSize="12"
                         Foreground="{StaticResource AppMutedTextBrush}"
                         Text="Search chats" />
            </StackPanel>
          </Border>

          <Button AutomationProperties.AutomationId="ChatStartNewButton"
                  Style="{StaticResource SidebarButtonStyle}">
            <StackPanel Orientation="Horizontal"
                        Spacing="8">
              <TextBlock FontSize="13"
                         Text="+" />
              <TextBlock Text="Start new chat" />
            </StackPanel>
          </Button>

          <ItemsControl AutomationProperties.AutomationId="ChatRecentChatsList"
                        ItemsSource="{Binding RecentChats}">
            <ItemsControl.ItemTemplate>
              <DataTemplate x:DataType="presentation:SidebarChatItem">
                <Grid Margin="0,0,0,8"
                      AutomationProperties.AutomationId="ChatRecentChatItem">
                  <Border Background="Transparent"
                          CornerRadius="16" />
                  <Border Background="{StaticResource AppSelectionBrush}"
                          CornerRadius="16"
                          Visibility="{Binding IsSelected}" />
                  <Grid Margin="12,10">
                    <Grid.RowDefinitions>
                      <RowDefinition Height="Auto" />
                      <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <TextBlock FontSize="14"
                               Text="{x:Bind Title}" />
                    <TextBlock Grid.Row="1"
                               Margin="0,2,0,0"
                               FontSize="12"
                               Foreground="{StaticResource AppMutedTextBrush}"
                               Text="{x:Bind Preview}"
                               TextTrimming="CharacterEllipsis" />
                  </Grid>
                </Grid>
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>
        </StackPanel>
      </ScrollViewer>

      <StackPanel Grid.Row="4">
        <Rectangle Margin="12,0,12,0"
                   Style="{StaticResource SectionDividerStyle}" />
        <Grid Margin="12,16,8,16"
              AutomationProperties.AutomationId="ChatSidebarProfile"
              ColumnSpacing="10">
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="Auto" />
          </Grid.ColumnDefinitions>

          <Border Width="32"
                  Height="32"
                  Background="{StaticResource UserAvatarBrush}"
                  CornerRadius="16">
            <TextBlock HorizontalAlignment="Center"
                       VerticalAlignment="Center"
                       FontSize="12"
                       FontWeight="SemiBold"
                       Foreground="White"
                       Text="J" />
          </Border>

          <StackPanel Grid.Column="1"
                      Spacing="0">
            <TextBlock FontSize="12"
                       FontWeight="SemiBold"
                       Text="Jordan Lee" />
            <TextBlock FontSize="11"
                       Foreground="{StaticResource AppMutedTextBrush}"
                       Text="Pro plan - Active" />
          </StackPanel>

          <TextBlock Grid.Column="2"
                     VerticalAlignment="Center"
                     FontSize="16"
                     Foreground="{StaticResource AppMutedTextBrush}"
                     Text="..." />
        </Grid>
      </StackPanel>
    </Grid>
  </Border>
</UserControl>
