<UserControl x:Class="DotPilot.Presentation.Controls.ChatSidebar"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:uen="using:Uno.Extensions.Navigation.UI"
             xmlns:presentation="using:DotPilot.Presentation"
             AutomationProperties.AutomationId="ChatSidebar">
  <Border Style="{StaticResource GlassPanelStyle}"
          Padding="0">
    <Grid>
      <Grid.RowDefinitions>
        <RowDefinition Height="Auto" />
        <RowDefinition Height="Auto" />
        <RowDefinition Height="Auto" />
        <RowDefinition Height="*" />
        <RowDefinition Height="Auto" />
      </Grid.RowDefinitions>

      <StackPanel Margin="16,18,16,0"
                  AutomationProperties.AutomationId="ChatSidebarBrand"
                  Orientation="Horizontal"
                  Spacing="10">
        <Border Width="36"
                Height="36"
                Background="{StaticResource AppPrimaryTextBrush}"
                CornerRadius="11">
          <TextBlock HorizontalAlignment="Center"
                     VerticalAlignment="Center"
                     FontFamily="{StaticResource AppAccentFontFamily}"
                     FontSize="11"
                     Foreground="{StaticResource AppAccentBrush}"
                     Text="dp" />
        </Border>
        <TextBlock VerticalAlignment="Center"
                   FontSize="18"
                   FontWeight="SemiBold"
                   Foreground="{StaticResource AppPrimaryTextBrush}">
          <Run Text="dot" />
          <Run FontWeight="Normal"
               Foreground="{StaticResource AppMutedTextBrush}"
               Text="Pilot" />
        </TextBlock>
      </StackPanel>

      <StackPanel Grid.Row="1"
                  Margin="12,20,12,0"
                  AutomationProperties.AutomationId="ChatSidebarNavigation"
                  Spacing="4">
        <Button AutomationProperties.AutomationId="ChatNavButton"
                Style="{StaticResource SidebarButtonSelectedStyle}">
          <StackPanel Orientation="Horizontal"
                      Spacing="8">
            <TextBlock VerticalAlignment="Center"
                       FontSize="13"
                       Text="o" />
            <TextBlock VerticalAlignment="Center"
                       Text="Chat" />
          </StackPanel>
        </Button>
        <Button AutomationProperties.AutomationId="AgentsNavButton"
                Style="{StaticResource SidebarButtonStyle}"
                uen:Navigation.Request="Second">
          <StackPanel Orientation="Horizontal"
                      Spacing="8">
            <TextBlock VerticalAlignment="Center"
                       FontSize="13"
                       Text="*" />
            <TextBlock VerticalAlignment="Center"
                       Text="Agents" />
          </StackPanel>
        </Button>
        <Button AutomationProperties.AutomationId="ProvidersNavButton"
                Style="{StaticResource SidebarButtonStyle}"
                uen:Navigation.Request="Settings">
          <StackPanel Orientation="Horizontal"
                      Spacing="8">
            <TextBlock VerticalAlignment="Center"
                       FontSize="13"
                       Text="=" />
            <TextBlock VerticalAlignment="Center"
                       Text="Providers" />
          </StackPanel>
        </Button>
      </StackPanel>

      <Rectangle Grid.Row="2"
                 Margin="12,18,12,0"
                 Style="{StaticResource SectionDividerStyle}" />

      <ScrollViewer Grid.Row="3"
                    VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="12,20,12,20"
                    AutomationProperties.AutomationId="ChatSidebarContent"
                    Spacing="16">
          <TextBlock Margin="12,0,0,0"
                     CharacterSpacing="80"
                     FontSize="12"
                     FontWeight="Medium"
                     Foreground="{StaticResource AppMutedTextBrush}"
                     Text="SESSIONS" />

          <Button AutomationProperties.AutomationId="ChatStartNewButton"
                  Command="{Binding StartNewSessionCommand}"
                  Style="{StaticResource SidebarButtonStyle}">
            <StackPanel Orientation="Horizontal"
                        Spacing="8">
              <TextBlock FontSize="13"
                         Text="+" />
              <TextBlock Text="Start new session" />
            </StackPanel>
          </Button>

          <Button AutomationProperties.AutomationId="ChatRefreshButton"
                  Command="{Binding RefreshCommand}"
                  Style="{StaticResource SidebarButtonStyle}">
            <StackPanel Orientation="Horizontal"
                        Spacing="8">
              <TextBlock FontSize="13"
                         Text="o" />
              <TextBlock Text="Refresh sessions" />
            </StackPanel>
          </Button>

          <TextBlock AutomationProperties.AutomationId="ChatSidebarFeedback"
                     FontSize="12"
                     Foreground="{StaticResource AppMutedTextBrush}"
                     Text="{Binding FeedbackMessage}"
                     TextWrapping="WrapWholeWords" />

          <ListView AutomationProperties.AutomationId="ChatRecentChatsList"
                    Background="Transparent"
                    BorderBrush="Transparent"
                    BorderThickness="0"
                    ItemsSource="{Binding RecentChats}"
                    SelectedItem="{Binding SelectedChat, Mode=TwoWay}"
                    SelectionMode="Single">
            <ListView.ItemTemplate>
              <DataTemplate x:DataType="presentation:SessionSidebarItem">
                <Border Background="{StaticResource AppSoftSurfaceBrush}"
                        BorderBrush="{StaticResource AppOutlineBrush}"
                        BorderThickness="1"
                        CornerRadius="16"
                        Margin="0,0,0,10"
                        Padding="12,10"
                        AutomationProperties.AutomationId="ChatRecentChatItem">
                  <StackPanel Spacing="4">
                    <TextBlock FontSize="13"
                               FontWeight="SemiBold"
                               Text="{x:Bind Title}" />
                    <TextBlock FontSize="11"
                               Foreground="{StaticResource AppMutedTextBrush}"
                               Text="{x:Bind Preview}"
                               TextTrimming="CharacterEllipsis"
                               TextWrapping="WrapWholeWords" />
                  </StackPanel>
                </Border>
              </DataTemplate>
            </ListView.ItemTemplate>
          </ListView>
        </StackPanel>
      </ScrollViewer>

      <StackPanel Grid.Row="4">
        <Rectangle Margin="12,0,12,0"
                   Style="{StaticResource SectionDividerStyle}" />
        <Grid Margin="12,16,8,16"
              AutomationProperties.AutomationId="ChatSidebarProfile"
              ColumnSpacing="10">
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="Auto" />
          </Grid.ColumnDefinitions>

          <Border Width="32"
                  Height="32"
                  Background="{StaticResource UserAvatarBrush}"
                  CornerRadius="16">
            <TextBlock HorizontalAlignment="Center"
                       VerticalAlignment="Center"
                       FontSize="12"
                       FontWeight="SemiBold"
                       Foreground="White"
                       Text="L" />
          </Border>

          <StackPanel Grid.Column="1"
                      Spacing="0">
            <TextBlock FontSize="12"
                       FontWeight="SemiBold"
                       Text="Local operator" />
            <TextBlock FontSize="11"
                       Foreground="{StaticResource AppMutedTextBrush}"
                       Text="Desktop session host" />
          </StackPanel>

          <TextBlock Grid.Column="2"
                     VerticalAlignment="Center"
                     FontSize="16"
                     Foreground="{StaticResource AppMutedTextBrush}"
                     Text="..." />
        </Grid>
      </StackPanel>
    </Grid>
  </Border>
</UserControl>
