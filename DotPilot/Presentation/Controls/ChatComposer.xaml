<UserControl x:Class="DotPilot.Presentation.Controls.ChatComposer"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Name="Root"
             AutomationProperties.AutomationId="ChatComposer">
  <StackPanel Spacing="12">
    <TextBlock AutomationProperties.AutomationId="ChatComposerStatus"
               Foreground="{StaticResource AppMutedTextBrush}"
               Text="{Binding FeedbackMessage}"
               TextWrapping="WrapWholeWords" />

    <Border Style="{StaticResource ChatComposerCardStyle}">
      <Grid AutomationProperties.AutomationId="ChatComposerBar"
            RowSpacing="12">
        <Grid.RowDefinitions>
          <RowDefinition Height="Auto" />
          <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0"
                    Spacing="8">
          <TextBlock Style="{StaticResource ChatComposerLabelTextStyle}"
                     Text="Message" />
          <TextBox x:Name="ComposerInput"
                   AutomationProperties.AutomationId="ChatComposerInput"
                   KeyDown="OnComposerInputKeyDown"
                   PlaceholderText="{Binding ComposerPlaceholder}"
                   Style="{StaticResource ChatComposerTextBoxStyle}"
                   Text="{Binding ComposerText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
        </StackPanel>

        <Grid Grid.Row="1"
              ColumnSpacing="12">
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="Auto" />
          </Grid.ColumnDefinitions>

          <StackPanel VerticalAlignment="Center"
                      Spacing="2">
            <TextBlock Style="{StaticResource ChatComposerLabelTextStyle}"
                       Text="Send behavior" />
            <TextBlock AutomationProperties.AutomationId="ChatComposerHint"
                       Style="{StaticResource ChatComposerHintTextStyle}"
                       Text="{Binding ComposerSendHint}" />
          </StackPanel>

          <Button Grid.Column="1"
                  AutomationProperties.AutomationId="ChatStartSessionButton"
                  Command="{Binding StartNewSessionCommand}"
                  Style="{StaticResource SecondaryActionButtonStyle}">
            <TextBlock FontSize="12"
                       Text="Start session" />
          </Button>

          <Button x:Name="SendButton"
                  Grid.Column="2"
                  AutomationProperties.AutomationId="ChatComposerSendButton"
                  Click="OnSendButtonClick"
                  Command="{Binding SubmitMessageCommand}"
                  CommandParameter="{Binding Text, ElementName=ComposerInput}"
                  Style="{StaticResource AccentActionButtonStyle}">
            <Grid ColumnSpacing="8">
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
              </Grid.ColumnDefinitions>
              <SymbolIcon Symbol="Send" />
              <TextBlock Grid.Column="1"
                         Text="Send" />
            </Grid>
          </Button>
        </Grid>
      </Grid>
    </Border>
  </StackPanel>
</UserControl>
