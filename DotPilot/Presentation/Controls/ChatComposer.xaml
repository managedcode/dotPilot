<UserControl x:Class="DotPilot.Presentation.Controls.ChatComposer"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             AutomationProperties.AutomationId="ChatComposer">
  <Border Background="{StaticResource AppInputSurfaceBrush}"
          BorderBrush="{StaticResource AppOutlineBrush}"
          BorderThickness="1"
          CornerRadius="100"
          Padding="8">
    <Grid AutomationProperties.AutomationId="ChatComposerBar"
          ColumnSpacing="8">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="Auto" />
        <ColumnDefinition Width="*" />
        <ColumnDefinition Width="Auto" />
        <ColumnDefinition Width="Auto" />
      </Grid.ColumnDefinitions>

      <Button AutomationProperties.AutomationId="ChatComposerAttachButton"
              Background="{StaticResource AppSoftSurfaceBrush}"
              BorderBrush="{StaticResource AppOutlineBrush}"
              BorderThickness="1"
              CornerRadius="22"
              Padding="0"
              Width="44"
              Height="44">
        <TextBlock HorizontalAlignment="Center"
                   VerticalAlignment="Center"
                   FontSize="14"
                   Foreground="{StaticResource AppMutedTextBrush}"
                   Text="+" />
      </Button>

      <TextBox Grid.Column="1"
               AutomationProperties.AutomationId="ChatComposerInput"
               Background="Transparent"
               BorderBrush="Transparent"
               BorderThickness="0"
               FontSize="14"
               Foreground="{StaticResource AppPrimaryTextBrush}"
               PlaceholderText="Message"
               SelectionHighlightColor="{StaticResource AppAccentBrush}"
               VerticalAlignment="Center"
               VerticalContentAlignment="Center" />

      <Button Grid.Column="2"
              AutomationProperties.AutomationId="ChatComposerVoiceButton"
              Background="{StaticResource AppSoftSurfaceBrush}"
              BorderBrush="{StaticResource AppOutlineBrush}"
              BorderThickness="1"
              CornerRadius="22"
              Padding="0"
              Width="44"
              Height="44">
        <TextBlock HorizontalAlignment="Center"
                   VerticalAlignment="Center"
                   FontSize="14"
                   Foreground="{StaticResource AppMutedTextBrush}"
                   Text="o" />
      </Button>

      <Button Grid.Column="3"
              AutomationProperties.AutomationId="ChatComposerSendButton"
              Background="{StaticResource AppAccentBrush}"
              BorderBrush="Transparent"
              BorderThickness="0"
              CornerRadius="22"
              Padding="0"
              Width="44"
              Height="44">
        <TextBlock HorizontalAlignment="Center"
                   VerticalAlignment="Center"
                   FontSize="16"
                   FontWeight="SemiBold"
                   Foreground="{StaticResource AppPrimaryTextBrush}"
                   Text="^" />
      </Button>
    </Grid>
  </Border>
</UserControl>
