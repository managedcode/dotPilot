<UserControl x:Class="DotPilot.Presentation.Controls.ChatComposer"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Name="Root"
             AutomationProperties.AutomationId="ChatComposer">
  <StackPanel Spacing="10">
    <TextBlock AutomationProperties.AutomationId="ChatComposerStatus"
               Foreground="{StaticResource AppMutedTextBrush}"
               Text="{Binding FeedbackMessage}"
               TextWrapping="WrapWholeWords" />

    <Border Style="{StaticResource GlassPanelStyle}"
            Padding="14">
      <Grid AutomationProperties.AutomationId="ChatComposerBar"
            RowSpacing="12">
        <Grid.RowDefinitions>
          <RowDefinition Height="Auto" />
          <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBox x:Name="ComposerInput"
                 Grid.Row="0"
                 AutomationProperties.AutomationId="ChatComposerInput"
                 AcceptsReturn="True"
                 Background="Transparent"
                 BorderBrush="Transparent"
                 BorderThickness="0"
                 FontSize="14"
                 Foreground="{StaticResource AppPrimaryTextBrush}"
                 KeyDown="OnComposerInputKeyDown"
                 MaxHeight="168"
                 MinHeight="72"
                 PlaceholderText="{Binding ComposerPlaceholder}"
                 ScrollViewer.VerticalScrollBarVisibility="Auto"
                 SelectionHighlightColor="{StaticResource AppAccentBrush}"
                 Text="{Binding ComposerText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                 TextWrapping="Wrap"
                 VerticalAlignment="Stretch"
                 VerticalContentAlignment="Top" />

        <Grid Grid.Row="1"
              ColumnSpacing="12">
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="Auto" />
          </Grid.ColumnDefinitions>

          <TextBlock AutomationProperties.AutomationId="ChatComposerHint"
                     VerticalAlignment="Center"
                     FontSize="12"
                     Foreground="{StaticResource AppMutedTextBrush}"
                     Text="Enter sends. Shift or Alt with Enter adds a new line."
                     TextWrapping="WrapWholeWords" />

          <Button Grid.Column="1"
                  AutomationProperties.AutomationId="ChatStartSessionButton"
                  Background="{StaticResource AppSoftSurfaceBrush}"
                  Command="{Binding StartNewSessionCommand}"
                  Style="{StaticResource SecondaryActionButtonStyle}">
            <TextBlock FontSize="12"
                       Text="Start session" />
          </Button>

          <Button x:Name="SendButton"
                  Grid.Column="2"
                  AutomationProperties.AutomationId="ChatComposerSendButton"
                  Click="OnSendButtonClick"
                  Command="{Binding SubmitMessageCommand}"
                  CommandParameter="{Binding Text, ElementName=ComposerInput}"
                  Style="{StaticResource AccentActionButtonStyle}">
            <Grid ColumnSpacing="8">
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
              </Grid.ColumnDefinitions>
              <SymbolIcon Symbol="Send" />
              <TextBlock Grid.Column="1"
                         Text="Send" />
            </Grid>
          </Button>
        </Grid>
      </Grid>
    </Border>
  </StackPanel>
</UserControl>
