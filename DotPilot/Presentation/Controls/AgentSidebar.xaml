<UserControl x:Class="DotPilot.Presentation.Controls.AgentSidebar"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:uen="using:Uno.Extensions.Navigation.UI"
             FontFamily="{StaticResource AppBodyFontFamily}">
  <Border Style="{StaticResource GlassPanelStyle}"
          AutomationProperties.AutomationId="AgentSidebar"
          Padding="0">
    <Grid>
      <Grid.RowDefinitions>
        <RowDefinition Height="Auto" />
        <RowDefinition Height="Auto" />
        <RowDefinition Height="Auto" />
        <RowDefinition Height="*" />
        <RowDefinition Height="Auto" />
      </Grid.RowDefinitions>

      <StackPanel Margin="16,18,16,0"
                  Orientation="Horizontal"
                  Spacing="10">
        <Border Width="36"
                Height="36"
                CornerRadius="11"
                Background="{StaticResource AppPrimaryTextBrush}">
          <TextBlock HorizontalAlignment="Center"
                     VerticalAlignment="Center"
                     FontFamily="{StaticResource AppAccentFontFamily}"
                     FontSize="11"
                     Foreground="{StaticResource AppAccentBrush}"
                     Text="dp" />
        </Border>
        <TextBlock VerticalAlignment="Center"
                   FontSize="18"
                   FontWeight="SemiBold"
                   Foreground="{StaticResource AppPrimaryTextBrush}">
          <Run Text="dot" />
          <Run Foreground="{StaticResource AppMutedTextBrush}"
               FontWeight="Normal"
               Text="Pilot" />
        </TextBlock>
      </StackPanel>

      <StackPanel Grid.Row="1"
                  Margin="12,20,12,0"
                  Spacing="4">
        <Button Style="{StaticResource SidebarButtonStyle}"
                AutomationProperties.AutomationId="SidebarChatButton"
                uen:Navigation.Request="-">
          <StackPanel Orientation="Horizontal"
                      Spacing="8">
            <TextBlock VerticalAlignment="Center"
                       FontSize="13"
                       Text="◌" />
            <TextBlock VerticalAlignment="Center"
                       Text="Chat" />
          </StackPanel>
        </Button>
        <Button Style="{StaticResource SidebarButtonSelectedStyle}"
                AutomationProperties.AutomationId="SidebarAgentsButton">
          <StackPanel Orientation="Horizontal"
                      Spacing="8">
            <TextBlock VerticalAlignment="Center"
                       FontSize="13"
                       Text="✦" />
            <TextBlock VerticalAlignment="Center"
                       Text="Agents" />
          </StackPanel>
        </Button>
      </StackPanel>

      <Rectangle Grid.Row="2"
                 Style="{StaticResource SectionDividerStyle}"
                 Margin="12,18,12,0" />

      <StackPanel Grid.Row="3"
                  Margin="12,20,12,0"
                  Spacing="16">
        <TextBlock Margin="12,0,0,0"
                   FontSize="12"
                   FontWeight="Medium"
                   Foreground="{StaticResource AppMutedTextBrush}"
                   Text="Agents" />

        <Border Style="{StaticResource PrimaryCapsuleStyle}"
                AutomationProperties.AutomationId="CreateAgentSidebarButton"
                Padding="14,10">
          <StackPanel HorizontalAlignment="Center"
                      Orientation="Horizontal"
                      Spacing="8">
            <TextBlock FontSize="13"
                       Foreground="{StaticResource AppAccentBrush}"
                       Text="✦" />
            <TextBlock FontSize="13"
                       FontWeight="SemiBold"
                       Foreground="{StaticResource AppInputSurfaceBrush}"
                       Text="Create new agent" />
          </StackPanel>
        </Border>

        <ItemsControl AutomationProperties.AutomationId="ExistingAgentsList"
                      ItemsSource="{Binding ExistingAgents}">
          <ItemsControl.ItemTemplate>
            <DataTemplate>
              <Grid Height="48"
                    Margin="0,0,0,12"
                    ColumnSpacing="8">
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="Auto" />
                  <ColumnDefinition Width="*" />
                  <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <Border Width="32"
                        Height="32"
                        CornerRadius="16"
                        Background="{Binding AvatarBrush}"
                        VerticalAlignment="Center">
                  <TextBlock HorizontalAlignment="Center"
                             VerticalAlignment="Center"
                             FontSize="12"
                             FontWeight="Bold"
                             Foreground="{StaticResource AppInputSurfaceBrush}"
                             Text="{Binding Initial}" />
                </Border>
                <StackPanel Grid.Column="1"
                            VerticalAlignment="Center"
                            Spacing="2">
                  <TextBlock FontSize="14"
                             FontWeight="SemiBold"
                             Text="{Binding Name}" />
                  <TextBlock FontSize="11.5"
                             Foreground="{StaticResource AppMutedTextBrush}"
                             Text="{Binding ModelSummary}" />
                </StackPanel>
                <TextBlock Grid.Column="2"
                           VerticalAlignment="Center"
                           FontSize="16"
                           Foreground="{StaticResource AppMutedTextBrush}"
                           Text="⋯" />
              </Grid>
            </DataTemplate>
          </ItemsControl.ItemTemplate>
        </ItemsControl>
      </StackPanel>

      <Rectangle Grid.Row="4"
                 VerticalAlignment="Top"
                 Style="{StaticResource SectionDividerStyle}"
                 Margin="12,0,12,0" />
      <Grid Grid.Row="4"
            Margin="12,16,8,16"
            ColumnSpacing="10">
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="Auto" />
          <ColumnDefinition Width="*" />
          <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>
        <Border Width="32"
                Height="32"
                CornerRadius="16"
                Background="{StaticResource UserAvatarBrush}">
          <TextBlock HorizontalAlignment="Center"
                     VerticalAlignment="Center"
                     FontSize="12"
                     FontWeight="SemiBold"
                     Foreground="{StaticResource AppInputSurfaceBrush}"
                     Text="J" />
        </Border>
        <StackPanel Grid.Column="1"
                    Spacing="0">
          <TextBlock FontSize="12"
                     FontWeight="SemiBold"
                     Text="Jordan Lee" />
          <TextBlock FontSize="11"
                     Foreground="{StaticResource AppMutedTextBrush}"
                     Text="Pro plan · Active" />
        </StackPanel>
        <TextBlock Grid.Column="2"
                   VerticalAlignment="Center"
                   FontSize="16"
                   Foreground="{StaticResource AppMutedTextBrush}"
                   Text="⋯" />
      </Grid>
    </Grid>
  </Border>
</UserControl>
