<UserControl x:Class="DotPilot.Presentation.Controls.AgentBasicInfoSection"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:presentation="using:DotPilot.Presentation"
             x:Name="Root"
             ProviderSelectionChangedCommand="{Binding ProviderSelectionChangedCommand}"
             SelectModelCommand="{Binding SelectModelCommand}"
             FontFamily="{StaticResource AppBodyFontFamily}">
  <Border Style="{StaticResource BuilderSectionStyle}"
          AutomationProperties.AutomationId="AgentBasicInfoSection">
    <StackPanel Spacing="18">
      <StackPanel Spacing="6">
        <TextBlock FontSize="18"
                   FontWeight="SemiBold"
                   Text="Profile" />
        <TextBlock FontSize="12"
                   Foreground="{StaticResource AppMutedTextBrush}"
                   Text="Review the generated profile and runtime defaults."
                   TextWrapping="WrapWholeWords" />
      </StackPanel>

      <Grid ColumnSpacing="16"
            RowSpacing="16">
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="1.15*" MinWidth="260" />
          <ColumnDefinition Width="*" MinWidth="240" />
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
          <RowDefinition Height="Auto" />
          <RowDefinition Height="Auto" />
          <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Spacing="8">
          <TextBlock FontSize="12"
                     FontWeight="Medium"
                     Foreground="{StaticResource AppSecondaryTextBrush}"
                     Text="Agent name" />
          <Border Style="{StaticResource BuilderInputSurfaceStyle}">
            <TextBox AutomationProperties.AutomationId="AgentNameInput"
                     Style="{StaticResource BuilderTextBoxStyle}"
                     PlaceholderText="e.g. Repository reviewer"
                     Text="{Binding AgentName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
          </Border>
        </StackPanel>

        <StackPanel Grid.Column="1"
                    Spacing="8">
          <TextBlock FontSize="12"
                     FontWeight="Medium"
                     Foreground="{StaticResource AppSecondaryTextBrush}"
                     Text="Provider" />
          <Border Style="{StaticResource BuilderInputSurfaceStyle}"
                  Visibility="{Binding IsDesktopHead, ElementName=Root}">
            <ComboBox x:Name="ProviderCombo"
                      AutomationProperties.AutomationId="AgentProviderCombo"
                      SelectionChanged="OnProviderSelectionChanged"
                      Style="{StaticResource BuilderComboBoxStyle}"
                      DisplayMemberPath="DisplayName"
                      ItemsSource="{Binding Providers}"
                      SelectedValue="{Binding SelectedProviderKind, Mode=TwoWay}"
                      SelectedValuePath="Kind" />
          </Border>
          <ItemsControl AutomationProperties.AutomationId="AgentProviderBrowserOptions"
                        ItemsSource="{Binding Providers}"
                        Visibility="{Binding IsBrowserHead, ElementName=Root}">
            <ItemsControl.ItemsPanel>
              <ItemsPanelTemplate>
                <StackPanel Orientation="Horizontal"
                            Spacing="8" />
              </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
            <ItemsControl.ItemTemplate>
              <DataTemplate x:DataType="presentation:AgentProviderOption">
                <Button AutomationProperties.AutomationId="{x:Bind SelectionAutomationId}"
                        Click="OnProviderQuickSelectButtonClick"
                        CommandParameter="{x:Bind Kind}"
                        Style="{StaticResource InlineActionButtonStyle}">
                  <TextBlock Text="{x:Bind DisplayName}" />
                </Button>
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>
        </StackPanel>

        <StackPanel Grid.Row="1"
                    Grid.ColumnSpan="2"
                    Spacing="8">
          <TextBlock FontSize="12"
                     FontWeight="Medium"
                     Foreground="{StaticResource AppSecondaryTextBrush}"
                     Text="Model" />
          <Border Style="{StaticResource BuilderInputSurfaceStyle}"
                  Visibility="{Binding IsDesktopHead, ElementName=Root}">
            <ComboBox AutomationProperties.AutomationId="AgentModelInput"
                      IsEnabled="{Binding Builder.HasSupportedModels}"
                      ItemsSource="{Binding Builder.SupportedModelNames}"
                      PlaceholderText="{Binding Builder.SuggestedModelName}"
                      SelectedItem="{Binding ModelName, Mode=TwoWay}"
                      Style="{StaticResource BuilderComboBoxStyle}" />
          </Border>
          <ItemsControl AutomationProperties.AutomationId="AgentModelBrowserOptions"
                        ItemsSource="{Binding Builder.SupportedModels}"
                        Visibility="{Binding IsBrowserHead, ElementName=Root}">
            <ItemsControl.ItemsPanel>
              <ItemsPanelTemplate>
                <StackPanel Orientation="Horizontal"
                            Spacing="8" />
              </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
            <ItemsControl.ItemTemplate>
              <DataTemplate x:DataType="presentation:AgentModelOption">
                <Button AutomationProperties.AutomationId="{x:Bind SelectionAutomationId}"
                        Click="OnModelQuickSelectButtonClick"
                        CommandParameter="{x:Bind DisplayName}"
                        Style="{StaticResource InlineActionButtonStyle}">
                  <TextBlock Text="{x:Bind DisplayName}" />
                </Button>
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>
          <TextBlock AutomationProperties.AutomationId="AgentSuggestedModelText"
                     FontSize="11.5"
                     Foreground="{StaticResource AppMutedTextBrush}"
                     Text="{Binding Builder.ModelHelperText}"
                     TextWrapping="WrapWholeWords" />
        </StackPanel>

        <StackPanel Grid.Row="2"
                    Grid.ColumnSpan="2"
                    AutomationProperties.AutomationId="AgentProviderSummaryCard"
                    Spacing="4">
          <TextBlock FontSize="12"
                     FontWeight="Medium"
                     Foreground="{StaticResource AppSecondaryTextBrush}"
                     Text="Provider status" />
          <TextBlock AutomationProperties.AutomationId="AgentSelectedProviderText"
                     FontSize="13"
                     FontWeight="SemiBold"
                     Text="{Binding Builder.ProviderDisplayName}" />
          <TextBlock FontSize="11.5"
                     Foreground="{StaticResource AppMutedTextBrush}"
                     Text="{Binding Builder.ProviderStatusSummary}"
                     TextWrapping="WrapWholeWords" />
          <TextBlock FontSize="11.5"
                     Foreground="{StaticResource AppSecondaryTextBrush}"
                     Text="{Binding Builder.ProviderCommandName}" />
          <TextBlock FontSize="11.5"
                     Foreground="{StaticResource AppSecondaryTextBrush}"
                     Text="{Binding Builder.ProviderVersionLabel}"
                     Visibility="{Binding Builder.HasProviderVersion}" />
        </StackPanel>
      </Grid>
    </StackPanel>
  </Border>
</UserControl>
