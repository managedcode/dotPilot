<UserControl x:Class="DotPilot.Presentation.Controls.AgentPromptSection"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Name="Root"
             FontFamily="{StaticResource AppBodyFontFamily}">
  <Border Style="{StaticResource BuilderSectionStyle}"
          AutomationProperties.AutomationId="AgentPromptSection">
    <StackPanel Spacing="18">
      <StackPanel Spacing="6">
        <TextBlock FontSize="18"
                   FontWeight="SemiBold"
                   Text="Instructions" />
        <TextBlock FontSize="12"
                   Foreground="{StaticResource AppMutedTextBrush}"
                   Text="Adjust the description and operating instructions before saving."
                   TextWrapping="WrapWholeWords" />
      </StackPanel>

      <StackPanel Spacing="8">
        <TextBlock FontSize="12"
                   FontWeight="Medium"
                   Foreground="{StaticResource AppSecondaryTextBrush}"
                   Text="Description" />
        <Border Style="{StaticResource BuilderInputSurfaceStyle}">
          <TextBox x:Name="DescriptionInput"
                   AutomationProperties.AutomationId="AgentDescriptionInput"
                   Style="{StaticResource BuilderTextBoxStyle}"
                   PlaceholderText="Briefly describe what this agent does."
                   Text="{Binding AgentDescription, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                   TextWrapping="Wrap" />
        </Border>
      </StackPanel>

      <StackPanel Spacing="8">
        <TextBlock FontSize="12"
                   FontWeight="Medium"
                   Foreground="{StaticResource AppSecondaryTextBrush}"
                   Text="System prompt" />
        <Border Style="{StaticResource BuilderSummaryCardStyle}"
                MinHeight="224">
          <TextBox x:Name="SystemPromptInput"
                   AutomationProperties.AutomationId="AgentSystemPromptInput"
                   AcceptsReturn="True"
                   Style="{StaticResource BuilderTextBoxStyle}"
                   Foreground="{StaticResource AppPrimaryTextBrush}"
                   Text="{Binding SystemPrompt, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                   TextWrapping="Wrap" />
        </Border>
      </StackPanel>

      <Grid ColumnSpacing="16">
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="*" />
          <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>
        <StackPanel Grid.Column="0"
                    VerticalAlignment="Center"
                    Spacing="4">
          <TextBlock AutomationProperties.AutomationId="AgentCreateHelperMessage"
                     FontSize="12"
                     Foreground="{StaticResource AppMutedTextBrush}"
                     Text="{Binding BuilderStatusMessage}"
                     TextWrapping="WrapWholeWords" />
          <TextBlock AutomationProperties.AutomationId="AgentCreateStatusMessage"
                     FontSize="12"
                     Foreground="{StaticResource AppPrimaryTextBrush}"
                     Text="{Binding OperationMessage}"
                     TextWrapping="WrapWholeWords" />
        </StackPanel>
        <Button x:Name="SaveAgentActionButton"
                Grid.Column="1"
                AutomationProperties.AutomationId="SaveAgentButton"
                Click="OnSaveAgentButtonClick"
                Tag="{Binding SaveAgentCommand}"
                Style="{StaticResource AccentActionButtonStyle}">
          <TextBlock Text="Save agent" />
        </Button>
      </Grid>
    </StackPanel>
  </Border>
</UserControl>
