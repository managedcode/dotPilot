<UserControl x:Class="DotPilot.Presentation.Controls.AgentCatalogSection"
             x:Name="Root"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:presentation="using:DotPilot.Presentation"
             FontFamily="{StaticResource AppBodyFontFamily}">
  <Border Style="{StaticResource BuilderSectionStyle}"
          AutomationProperties.AutomationId="AgentCatalogSection">
    <StackPanel Spacing="18">
      <Grid ColumnSpacing="12">
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="*" />
          <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>

        <StackPanel Spacing="6">
          <TextBlock FontSize="20"
                     FontWeight="SemiBold"
                     Text="All agents" />
          <TextBlock FontSize="12"
                     Foreground="{StaticResource AppMutedTextBrush}"
                     Text="System and saved local agents."
                     TextWrapping="WrapWholeWords" />
        </StackPanel>

        <Button Grid.Column="1"
                AutomationProperties.AutomationId="OpenCreateAgentButton"
                Click="OnOpenCreateAgentButtonClick"
                Style="{StaticResource AccentActionButtonStyle}"
                VerticalAlignment="Top">
          <TextBlock Text="New agent" />
        </Button>
      </Grid>

      <TextBlock AutomationProperties.AutomationId="AgentCatalogStatusMessage"
                 FontSize="12"
                 Foreground="{StaticResource AppMutedTextBrush}"
                 Text="{Binding OperationMessage}"
                 TextWrapping="WrapWholeWords" />

      <ItemsControl AutomationProperties.AutomationId="AgentCatalogList"
                    ItemsSource="{Binding Agents}">
        <ItemsControl.ItemTemplate>
          <DataTemplate x:DataType="presentation:AgentCatalogItem">
            <Border Background="{StaticResource AppInputSurfaceBrush}"
                    BorderBrush="{StaticResource AppOutlineBrush}"
                    BorderThickness="1"
                    CornerRadius="10"
                    Margin="0,0,0,10"
                    Padding="14,12"
                    AutomationProperties.AutomationId="AgentCatalogItem">
              <Grid ColumnSpacing="16"
                    RowSpacing="10">
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="*" />
                  <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                  <RowDefinition Height="Auto" />
                  <RowDefinition Height="Auto" />
                  <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Grid ColumnSpacing="10">
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                  </Grid.ColumnDefinitions>

                  <Border Width="34"
                          Height="34"
                          Background="{StaticResource DesignAvatarBrush}"
                          CornerRadius="17">
                    <TextBlock HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               FontSize="12"
                               FontWeight="SemiBold"
                               Foreground="White"
                               Text="{x:Bind Initial}" />
                  </Border>

                  <StackPanel Grid.Column="1"
                              Spacing="4"
                              VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal"
                                Spacing="8">
                      <TextBlock FontSize="13.5"
                                 FontWeight="SemiBold"
                                 Text="{x:Bind Name}" />
                      <Border Style="{StaticResource StatusChipStyle}"
                              Visibility="{x:Bind IsDefault}">
                        <TextBlock FontSize="10"
                                   FontWeight="SemiBold"
                                   Text="Default" />
                      </Border>
                    </StackPanel>
                    <TextBlock FontSize="11.5"
                               Foreground="{StaticResource AppMutedTextBrush}"
                               Text="{x:Bind ProviderDisplayName}" />
                  </StackPanel>
                </Grid>

                <TextBlock Grid.Row="1"
                           FontSize="12"
                           Foreground="{StaticResource AppSecondaryTextBrush}"
                           Text="{x:Bind Description}"
                           TextWrapping="WrapWholeWords" />

                <StackPanel Grid.Row="2"
                            Orientation="Horizontal"
                            Spacing="8">
                  <Border Style="{StaticResource StatusChipStyle}">
                    <TextBlock FontSize="10.5"
                               Foreground="{StaticResource AppMutedTextBrush}"
                               Text="{x:Bind ModelName}" />
                  </Border>
                </StackPanel>

                <Button Grid.Column="1"
                        Grid.RowSpan="3"
                        AutomationProperties.AutomationId="{x:Bind StartChatAutomationId}"
                        Command="{x:Bind StartChatCommand}"
                        CommandParameter="{x:Bind StartChatRequest}"
                        Style="{StaticResource InlineActionButtonStyle}"
                        VerticalAlignment="Center">
                  <TextBlock Text="Start chat" />
                </Button>
              </Grid>
            </Border>
          </DataTemplate>
        </ItemsControl.ItemTemplate>
      </ItemsControl>
    </StackPanel>
  </Border>
</UserControl>
