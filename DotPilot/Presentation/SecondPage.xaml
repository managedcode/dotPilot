<Page x:Class="DotPilot.Presentation.SecondPage"
      x:Name="Root"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:controls="using:DotPilot.Presentation.Controls"
      xmlns:uen="using:Uno.Extensions.Navigation.UI"
      xmlns:utu="using:Uno.Toolkit.UI"
      Background="{StaticResource AppShellBackgroundBrush}"
      FontFamily="{StaticResource AppBodyFontFamily}">
  <Grid utu:SafeArea.Insets="VisibleBounds"
        AutomationProperties.AutomationId="AgentBuilderScreen">
    <Canvas IsHitTestVisible="False">
      <Ellipse Width="540"
               Height="473"
               Canvas.Left="-207"
               Canvas.Top="482"
               Fill="{StaticResource AnalyticsAvatarBrush}"
               Opacity="0.18" />
      <Ellipse Width="887"
               Height="777"
               Canvas.Left="1007"
               Canvas.Top="-264"
               Fill="{StaticResource UserAvatarBrush}"
               Opacity="0.14" />
    </Canvas>

    <Grid Margin="12"
          ColumnSpacing="20">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="260" />
        <ColumnDefinition Width="*" />
      </Grid.ColumnDefinitions>

      <controls:AgentSidebar />

      <ScrollViewer Grid.Column="1"
                    HorizontalScrollBarVisibility="Disabled"
                    VerticalScrollBarVisibility="Auto">
        <StackPanel MaxWidth="1120"
                    HorizontalAlignment="Stretch"
                    Spacing="16">
          <Grid Margin="0,28,0,8"
                ColumnSpacing="16">
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="*" />
              <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <StackPanel Spacing="8">
              <TextBlock FontSize="22"
                         FontWeight="SemiBold"
                         Text="{Binding PageTitle}" />
              <TextBlock FontSize="14"
                         Foreground="{StaticResource AppMutedTextBrush}"
                         Text="{Binding PageSubtitle}" />
              <Border Style="{StaticResource GlassPanelStyle}"
                      AutomationProperties.AutomationId="AgentBuilderRuntimeBanner"
                      Padding="14,12">
                <StackPanel Spacing="6">
                  <TextBlock AutomationProperties.AutomationId="AgentBuilderRuntimeIssueLabel"
                             CharacterSpacing="80"
                             FontSize="11"
                             FontWeight="Medium"
                             Foreground="{StaticResource AppMutedTextBrush}"
                             Text="{Binding RuntimeFoundation.EpicLabel}" />
                  <TextBlock AutomationProperties.AutomationId="AgentBuilderRuntimeSummary"
                             FontSize="13"
                             FontWeight="SemiBold"
                             Foreground="{StaticResource AppPrimaryTextBrush}"
                             Text="{Binding RuntimeFoundation.Summary}"
                             TextWrapping="WrapWholeWords" />
                  <TextBlock AutomationProperties.AutomationId="AgentBuilderRuntimeClient"
                             FontSize="12"
                             Foreground="{StaticResource AppMutedTextBrush}"
                             Text="{Binding RuntimeFoundation.DeterministicClientName}" />
                </StackPanel>
              </Border>
            </StackPanel>
            <Button Grid.Column="1"
                    Style="{StaticResource SidebarButtonStyle}"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Center"
                    AutomationProperties.AutomationId="BackToChatButton"
                    uen:Navigation.Request="-">
              <StackPanel Orientation="Horizontal"
                          Spacing="6">
                <TextBlock FontSize="14"
                           Text="←" />
                <TextBlock Text="Back to chat" />
              </StackPanel>
            </Button>
          </Grid>

          <controls:AgentBasicInfoSection />

          <Grid ColumnSpacing="20">
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="2*" />
              <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <controls:AgentPromptSection />
            <controls:AgentSkillsSection Grid.Column="1" />
          </Grid>
        </StackPanel>
      </ScrollViewer>
    </Grid>
  </Grid>
</Page>
