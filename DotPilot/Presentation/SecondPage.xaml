<Page x:Class="DotPilot.Presentation.SecondPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:controls="using:DotPilot.Presentation.Controls"
      xmlns:utu="using:Uno.Toolkit.UI"
      Background="{StaticResource AppShellBackgroundBrush}"
      FontFamily="{StaticResource AppBodyFontFamily}">
  <Grid utu:SafeArea.Insets="VisibleBounds"
        AutomationProperties.AutomationId="AgentBuilderScreen">
    <Canvas IsHitTestVisible="False">
      <Ellipse Width="540"
               Height="473"
               Canvas.Left="-207"
               Canvas.Top="482"
               Fill="{StaticResource AnalyticsAvatarBrush}"
               Opacity="0.18" />
      <Ellipse Width="887"
               Height="777"
               Canvas.Left="1007"
               Canvas.Top="-264"
               Fill="{StaticResource UserAvatarBrush}"
               Opacity="0.14" />
    </Canvas>

    <Grid Margin="16"
          ColumnSpacing="24">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="272" />
        <ColumnDefinition Width="*" />
      </Grid.ColumnDefinitions>

      <controls:AgentSidebar />

      <Grid Grid.Column="1"
            RowSpacing="20">
        <Grid.RowDefinitions>
          <RowDefinition Height="Auto" />
          <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <StackPanel Margin="0,20,0,4"
                    Spacing="6">
          <TextBlock FontSize="22"
                     FontWeight="SemiBold"
                     Text="{Binding PageTitle}" />
          <TextBlock FontSize="14"
                     Foreground="{StaticResource AppMutedTextBrush}"
                     Text="{Binding PageSubtitle}" />
        </StackPanel>

        <ScrollViewer Grid.Row="1"
                      HorizontalScrollBarVisibility="Disabled"
                      VerticalScrollBarVisibility="Auto">
          <StackPanel MaxWidth="1100"
                      HorizontalAlignment="Stretch"
                      Spacing="20">
            <controls:AgentBasicInfoSection />

            <Grid ColumnSpacing="20">
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.65*" />
                <ColumnDefinition Width="*" />
              </Grid.ColumnDefinitions>

              <controls:AgentPromptSection />
              <controls:AgentSkillsSection Grid.Column="1" />
            </Grid>
          </StackPanel>
        </ScrollViewer>
      </Grid>
    </Grid>
  </Grid>
</Page>
