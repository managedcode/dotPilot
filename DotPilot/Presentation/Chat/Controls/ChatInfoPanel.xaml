<UserControl x:Class="DotPilot.Presentation.Controls.ChatInfoPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="using:DotPilot.Presentation.Controls"
             xmlns:uen="using:Uno.Extensions.Navigation.UI"
             xmlns:presentation="using:DotPilot.Presentation"
             AutomationProperties.AutomationId="ChatInfoPanel">
  <UserControl.Resources>
    <DataTemplate x:Key="MemberTemplate"
                  x:DataType="presentation:ParticipantItem">
      <Grid Margin="0,0,0,10"
            AutomationProperties.AutomationId="ChatMemberItem"
            ColumnSpacing="10">
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="Auto" />
          <ColumnDefinition Width="*" />
          <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>

        <Border Width="32"
                Height="32"
                Background="{x:Bind AvatarBrush}"
                CornerRadius="16">
          <TextBlock HorizontalAlignment="Center"
                     VerticalAlignment="Center"
                     FontSize="12"
                     FontWeight="Bold"
                     Foreground="White"
                     Text="{x:Bind Initial}" />
        </Border>

        <StackPanel Grid.Column="1"
                    VerticalAlignment="Center"
                    Spacing="1">
          <TextBlock FontSize="14"
                     FontWeight="Medium"
                     Foreground="{StaticResource AppPrimaryTextBrush}"
                     Text="{x:Bind Name}" />
          <TextBlock FontSize="12"
                     Foreground="{StaticResource AppMutedTextBrush}"
                     Text="{x:Bind SecondaryText}" />
        </StackPanel>

        <Border Grid.Column="2"
                VerticalAlignment="Center"
                Background="{x:Bind BadgeBrush}"
                CornerRadius="100"
                Padding="8,2"
                Visibility="{x:Bind HasBadge}">
          <TextBlock FontSize="10"
                     Foreground="{StaticResource AppPrimaryTextBrush}"
                     Text="{x:Bind BadgeText}" />
        </Border>
      </Grid>
    </DataTemplate>

    <DataTemplate x:Key="AgentTemplate"
                  x:DataType="presentation:ParticipantItem">
      <Grid Margin="0,0,0,10"
            AutomationProperties.AutomationId="ChatAgentItem"
            ColumnSpacing="10">
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="Auto" />
          <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Border Width="32"
                Height="32"
                Background="{x:Bind AvatarBrush}"
                CornerRadius="16">
          <TextBlock HorizontalAlignment="Center"
                     VerticalAlignment="Center"
                     FontSize="12"
                     FontWeight="Bold"
                     Foreground="White"
                     Text="{x:Bind Initial}" />
        </Border>

        <StackPanel Grid.Column="1"
                    VerticalAlignment="Center"
                    Spacing="1">
          <TextBlock FontSize="14"
                     FontWeight="Medium"
                     Foreground="{StaticResource AppPrimaryTextBrush}"
                     Text="{x:Bind Name}" />
          <TextBlock FontSize="12"
                     Foreground="{StaticResource AppMutedTextBrush}"
                     Text="{x:Bind SecondaryText}" />
        </StackPanel>
      </Grid>
    </DataTemplate>
  </UserControl.Resources>

  <Border Style="{StaticResource ChatSurfacePanelStyle}"
          Padding="0">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
      <StackPanel Margin="18"
                  AutomationProperties.AutomationId="ChatInfoPanelContent"
                  Spacing="14">
        <Grid AutomationProperties.AutomationId="ChatInfoPanelHeader"
              ColumnSpacing="12">
          <TextBlock Style="{StaticResource ChatSectionTitleTextStyle}"
                     Text="Session details" />
        </Grid>

        <Border Style="{StaticResource MetricCardStyle}">
          <StackPanel Spacing="4">
            <TextBlock FontSize="14"
                       FontWeight="Medium"
                       Foreground="{StaticResource AppPrimaryTextBrush}"
                       Text="{Binding ActiveSession.Title}" />
            <TextBlock FontSize="12"
                       Foreground="{StaticResource AppMutedTextBrush}"
                       Text="{Binding ActiveSession.StatusSummary}"
                       TextWrapping="WrapWholeWords" />
          </StackPanel>
        </Border>

        <Grid ColumnSpacing="10">
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="*" />
          </Grid.ColumnDefinitions>

          <Button AutomationProperties.AutomationId="ChatInfoAgentsButton"
                  Style="{StaticResource SecondaryActionButtonStyle}"
                  uen:Navigation.Request="Agents">
            <TextBlock FontSize="12.5"
                       FontWeight="SemiBold"
                       Text="Agents" />
          </Button>

          <Button Grid.Column="1"
                  AutomationProperties.AutomationId="ChatInfoProvidersButton"
                  Style="{StaticResource SecondaryActionButtonStyle}"
                  uen:Navigation.Request="Settings">
            <TextBlock FontSize="12.5"
                       FontWeight="SemiBold"
                       Text="Providers" />
          </Button>
        </Grid>

        <controls:ChatFleetBoard />

        <StackPanel Spacing="8">
          <TextBlock CharacterSpacing="80"
                     FontSize="12"
                     FontWeight="Medium"
                     Foreground="{StaticResource AppMutedTextBrush}"
                     Text="MEMBERS" />
          <ItemsControl AutomationProperties.AutomationId="ChatMembersList"
                        ItemTemplate="{StaticResource MemberTemplate}"
                        ItemsSource="{Binding ActiveSession.Members}" />
        </StackPanel>

        <StackPanel Spacing="8">
          <TextBlock CharacterSpacing="80"
                     FontSize="12"
                     FontWeight="Medium"
                     Foreground="{StaticResource AppMutedTextBrush}"
                     Text="AGENTS" />
          <ItemsControl AutomationProperties.AutomationId="ChatAgentsList"
                        ItemTemplate="{StaticResource AgentTemplate}"
                        ItemsSource="{Binding ActiveSession.Agents}" />
        </StackPanel>
      </StackPanel>
    </ScrollViewer>
  </Border>
</UserControl>
