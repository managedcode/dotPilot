<UserControl x:Class="DotPilot.Presentation.Controls.ChatConversationView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="using:DotPilot.Presentation.Controls"
             xmlns:presentation="using:DotPilot.Presentation"
             AutomationProperties.AutomationId="ChatConversationView">
  <UserControl.Resources>
    <DataTemplate x:Key="IncomingMessageTemplate"
                  x:DataType="presentation:ChatTimelineItem">
      <Grid Margin="0,0,0,20"
            MaxWidth="720"
            AutomationProperties.AutomationId="ChatIncomingMessageItem">
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="Auto" />
          <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Border Width="34"
                Height="34"
                VerticalAlignment="Top"
                Background="{x:Bind AvatarBrush}"
                CornerRadius="17">
          <TextBlock HorizontalAlignment="Center"
                     VerticalAlignment="Center"
                     FontSize="12"
                     FontWeight="Bold"
                     Foreground="White"
                     Text="{x:Bind Initial}" />
        </Border>

        <StackPanel Grid.Column="1"
                    Margin="12,0,0,0"
                    MaxWidth="620"
                    Spacing="8">
          <StackPanel Orientation="Horizontal"
                      Spacing="8">
            <TextBlock FontSize="12"
                       FontWeight="SemiBold"
                       Foreground="{StaticResource AppSecondaryTextBrush}"
                       Text="{x:Bind Author}" />
            <TextBlock FontSize="10.5"
                       Foreground="{StaticResource AppMutedTextBrush}"
                       Text="{x:Bind Timestamp}" />
          </StackPanel>

          <Border Style="{StaticResource MetricCardStyle}"
                  CornerRadius="14,14,14,8">
            <StackPanel Spacing="6">
              <TextBlock FontSize="11"
                         AutomationProperties.AutomationId="ChatMessageAccent"
                         Foreground="{StaticResource AppMutedTextBrush}"
                         Text="{x:Bind AccentLabel}" />
              <TextBlock FontSize="14"
                         AutomationProperties.AutomationId="ChatMessageText"
                         Foreground="{StaticResource AppPrimaryTextBrush}"
                         LineHeight="22"
                         Text="{x:Bind Content}"
                         TextWrapping="Wrap" />
            </StackPanel>
          </Border>
        </StackPanel>
      </Grid>
    </DataTemplate>

    <DataTemplate x:Key="OutgoingMessageTemplate"
                  x:DataType="presentation:ChatTimelineItem">
      <StackPanel Margin="0,0,0,20"
                  HorizontalAlignment="Right"
                  MaxWidth="620"
                  Spacing="6"
                  AutomationProperties.AutomationId="ChatOutgoingMessageItem">
        <StackPanel HorizontalAlignment="Right"
                    Orientation="Horizontal"
                    Spacing="8">
          <TextBlock FontSize="10.5"
                     Foreground="{StaticResource AppMutedTextBrush}"
                     Text="{x:Bind Timestamp}" />
          <TextBlock FontSize="12"
                     FontWeight="SemiBold"
                     Foreground="{StaticResource AppSecondaryTextBrush}"
                     Text="{x:Bind Author}" />
        </StackPanel>

        <Border Background="{StaticResource AppDarkSurfaceBrush}"
                CornerRadius="14,14,8,14"
                Padding="15,12">
          <TextBlock FontSize="14"
                     AutomationProperties.AutomationId="ChatMessageText"
                     Foreground="White"
                     LineHeight="22"
                     Text="{x:Bind Content}"
                     TextWrapping="Wrap" />
        </Border>
      </StackPanel>
    </DataTemplate>

    <DataTemplate x:Key="ActivityMessageTemplate"
                  x:DataType="presentation:ChatTimelineItem">
      <Grid Margin="0,0,0,14"
            MaxWidth="760"
            AutomationProperties.AutomationId="ChatActivityItem">
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="Auto" />
          <ColumnDefinition Width="*" />
          <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0"
                Style="{StaticResource StatusChipStyle}"
                VerticalAlignment="Top"
                Padding="8,3">
          <TextBlock AutomationProperties.AutomationId="ChatActivityLabel"
                     FontSize="10.5"
                     FontWeight="SemiBold"
                     Foreground="{StaticResource AppPrimaryTextBrush}"
                     Text="{x:Bind AccentLabel}" />
        </Border>

        <TextBlock Grid.Column="1"
                   Margin="10,0,0,0"
                   AutomationProperties.AutomationId="ChatMessageText"
                   FontSize="12.5"
                   Foreground="{StaticResource AppSecondaryTextBrush}"
                   LineHeight="18"
                   Text="{x:Bind Content}"
                   TextWrapping="WrapWholeWords" />

        <TextBlock Grid.Column="2"
                   Margin="12,0,0,0"
                   VerticalAlignment="Top"
                   FontSize="10.5"
                   Foreground="{StaticResource AppMutedTextBrush}"
                   Text="{x:Bind Timestamp}" />
      </Grid>
    </DataTemplate>

    <controls:ChatMessageTemplateSelector x:Key="ChatMessageTemplateSelector"
                                          ActivityTemplate="{StaticResource ActivityMessageTemplate}"
                                          IncomingTemplate="{StaticResource IncomingMessageTemplate}"
                                          OutgoingTemplate="{StaticResource OutgoingMessageTemplate}" />
  </UserControl.Resources>

  <Grid RowSpacing="14">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
    </Grid.RowDefinitions>

    <Grid AutomationProperties.AutomationId="ChatConversationHeader"
          ColumnSpacing="12">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="Auto" />
        <ColumnDefinition Width="*" />
      </Grid.ColumnDefinitions>

      <Border Width="42"
              Height="42"
              Background="{StaticResource DesignAvatarBrush}"
              CornerRadius="21">
        <TextBlock HorizontalAlignment="Center"
                   VerticalAlignment="Center"
                   FontSize="15"
                   FontWeight="Bold"
                   Foreground="White"
                   Text="{Binding ActiveSession.Initial}" />
      </Border>

      <StackPanel Grid.Column="1"
                  Spacing="2">
        <TextBlock AutomationProperties.AutomationId="ChatTitleText"
                   FontSize="18"
                   FontWeight="SemiBold"
                   Foreground="{StaticResource AppPrimaryTextBrush}"
                   Text="{Binding ActiveSession.Title}" />
        <StackPanel Orientation="Horizontal"
                    Spacing="6">
          <Ellipse Width="7"
                   Height="7"
                   Fill="{StaticResource AppSuccessBrush}" />
          <TextBlock AutomationProperties.AutomationId="ChatStatusText"
                     FontSize="12.5"
                     Foreground="{StaticResource AppMutedTextBrush}"
                     Text="{Binding ActiveSession.StatusSummary}" />
        </StackPanel>
      </StackPanel>
    </Grid>

    <Border Grid.Row="1"
            Style="{StaticResource ChatSurfacePanelStyle}"
            Padding="0">
      <ScrollViewer x:Name="ConversationScrollViewer"
                    VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="22,20,22,22"
                    AutomationProperties.AutomationId="ChatMessagesRegion"
                    Spacing="18">
          <ItemsControl x:Name="MessagesList"
                        AutomationProperties.AutomationId="ChatMessagesList"
                        ItemTemplateSelector="{StaticResource ChatMessageTemplateSelector}"
                        ItemsSource="{Binding ActiveSession.Messages}" />
        </StackPanel>
      </ScrollViewer>
    </Border>
  </Grid>
</UserControl>
