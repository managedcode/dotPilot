<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

  <Style x:Key="SettingsSurfacePanelStyle" TargetType="Border" BasedOn="{StaticResource GlassPanelStyle}">
    <Setter Property="Padding" Value="0" />
    <Setter Property="CornerRadius" Value="16" />
  </Style>

  <Style x:Key="SettingsNavButtonStyle" TargetType="Button" BasedOn="{StaticResource ListEntryButtonStyle}">
    <Setter Property="Margin" Value="0,0,0,10" />
  </Style>

  <Style x:Key="SettingsCategoryCardStyle" TargetType="Border" BasedOn="{StaticResource MetricCardStyle}">
    <Setter Property="CornerRadius" Value="14" />
    <Setter Property="Padding" Value="14,12" />
  </Style>

  <Style x:Key="SettingsOptionCardStyle" TargetType="Border" BasedOn="{StaticResource MetricCardStyle}">
    <Setter Property="CornerRadius" Value="14" />
    <Setter Property="Padding" Value="16,14" />
  </Style>

  <Style x:Key="SettingsSectionTitleTextStyle" TargetType="TextBlock">
    <Setter Property="FontSize" Value="22" />
    <Setter Property="FontWeight" Value="SemiBold" />
    <Setter Property="Foreground" Value="{StaticResource AppPrimaryTextBrush}" />
  </Style>

  <Style x:Key="SettingsSectionSubtitleTextStyle" TargetType="TextBlock">
    <Setter Property="FontSize" Value="12.5" />
    <Setter Property="Foreground" Value="{StaticResource AppMutedTextBrush}" />
    <Setter Property="TextWrapping" Value="WrapWholeWords" />
  </Style>

</ResourceDictionary>
